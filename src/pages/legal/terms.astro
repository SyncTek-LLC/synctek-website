---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Content } from '../../content/legal/terms.md';

const effectiveDate = 'February 27, 2026';
const lastUpdated = 'February 27, 2026';
---

<BaseLayout
  title="Terms of Service - SyncTek LLC"
  description="Terms of Service for ForgeOS and SpecterQA, products of SyncTek LLC. Covers AI-generated output liability, multi-provider disclosure, federation, acceptable use, MCP tool restrictions, data handling, EU AI Act disclaimers, and governing law."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">

    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">LEGAL</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-[#E6EDF3] tracking-tight mb-4">
        Terms of Service
      </h1>
      <p class="text-[#8B949E]">
        Effective: {effectiveDate} &nbsp;&middot;&nbsp; Last updated: {lastUpdated}
      </p>
    </div>

    <!-- Markdown body -->
    <div class="prose legal-prose">
      <Content />
    </div>

    <!-- Footer cross-link -->
    <div class="mt-12 pt-8" style="border-top: 1px solid #1F1F1F;">
      <p class="text-sm text-[#8B949E]">
        Also see our <a href="/legal/privacy" class="text-[#3B82F6] hover:underline">Privacy Policy</a>.
      </p>
    </div>

  </div>
</BaseLayout>

<style>
  /* Legal prose overrides - dark theme */
  .legal-prose {
    color: #9CA3AF;
    line-height: 1.7;
    max-width: none;
  }

  .legal-prose :global(h1) {
    display: none; /* heading already in page header above */
  }

  .legal-prose :global(h2) {
    font-size: 1.2rem;
    font-weight: 600;
    color: #E6EDF3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1F1F1F;
  }

  .legal-prose :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: #E6EDF3;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .legal-prose :global(h4) {
    font-size: 0.95rem;
    font-weight: 600;
    color: #C9D1D9;
    margin-top: 1.25rem;
    margin-bottom: 0.4rem;
  }

  .legal-prose :global(p) {
    margin-bottom: 1rem;
  }

  .legal-prose :global(strong) {
    color: #E6EDF3;
    font-weight: 600;
  }

  .legal-prose :global(a) {
    color: #3B82F6;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-prose :global(a:hover) {
    color: #60A5FA;
  }

  .legal-prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .legal-prose :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .legal-prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .legal-prose :global(hr) {
    border: none;
    border-top: 1px solid #1F1F1F;
    margin: 2rem 0;
  }

  .legal-prose :global(code) {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.875em;
    background: #1A1A1A;
    border: 1px solid #2A2A2A;
    color: #E6EDF3;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }

  .legal-prose :global(pre) {
    background: #111111;
    border: 1px solid #1F1F1F;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .legal-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: #D4D4D4;
  }

  .legal-prose :global(blockquote) {
    border-left: 3px solid #1F1F1F;
    padding-left: 1rem;
    color: #8B949E;
    font-style: italic;
    margin-bottom: 1rem;
  }

  /* Tables */
  .legal-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }

  .legal-prose :global(thead tr) {
    border-bottom: 2px solid #1F1F1F;
  }

  .legal-prose :global(th) {
    text-align: left;
    padding: 0.6rem 0.75rem;
    color: #E6EDF3;
    font-weight: 600;
    white-space: nowrap;
  }

  .legal-prose :global(td) {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid #1F1F1F;
    color: #9CA3AF;
    vertical-align: top;
  }
</style>
