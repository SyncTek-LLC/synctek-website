---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<BaseLayout
  title="About SyncTek"
  description="SyncTek LLC is a Raleigh-based developer-infrastructure company building tools for the agent-first software development era. SimDrive is our flagship product."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Mission -->
    <div class="max-w-3xl mb-16">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">About SyncTek</h1>
      <p class="text-lg text-light-gray-500 dark:text-light-text mb-4">
        SyncTek LLC is a Raleigh-based developer-infrastructure company building tools for the
        agent-first software development era.
      </p>
      <p class="text-base text-light-gray-500 dark:text-light-text">
        Our flagship product is <a href="https://simdrive.dev" target="_blank" rel="noopener noreferrer" class="text-accent-silver no-underline hover:underline">SimDrive</a> —
        an MCP-native iOS simulator and real-device automation toolkit. More products are in the pipeline.
      </p>
    </div>

    <SectionDivider />

    <!-- What we build -->
    <div class="max-w-3xl mb-16 mt-16">
      <h2 class="text-2xl font-semibold tracking-tight mb-6">What we build</h2>
      <div class="space-y-4 text-light-gray-500 dark:text-light-text">
        <p>
          We build infrastructure that lets AI agents do real engineering work — not just describe it.
          SimDrive is the first product in that line: it gives Claude and other MCP-aware agents the ability
          to drive iOS simulators and real devices the way a human engineer would.
        </p>
        <p>
          The bet behind SyncTek is that software development is rapidly becoming a collaboration between
          humans and agents, and the toolchain has not caught up. We are building for that gap.
        </p>
      </div>
    </div>

    <SectionDivider />

    <!-- Contact CTA -->
    <div class="max-w-3xl mt-16">
      <div class="rounded-lg border border-light-border dark:border-border-gray p-8">
        <h2 class="text-xl font-semibold tracking-tight mb-4">Get in touch</h2>
        <p class="text-light-gray-500 dark:text-light-text mb-4">
          Questions about SimDrive, partnerships, or anything else — we would like to hear from you.
        </p>
        <a
          href="/contact/"
          class="inline-flex items-center px-6 py-3 rounded-lg bg-accent-silver text-obsidian font-semibold no-underline hover:bg-accent-silver-hover transition-colors"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
