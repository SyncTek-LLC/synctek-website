---
import BaseLayout from '../layouts/BaseLayout.astro';
import forgeos from '../data/products/forgeos';
import specterqa from '../data/products/specterqa';

const products = [forgeos, specterqa];
---

<BaseLayout
  title="Contact"
  description="Get in touch with the SyncTek team. Bug reports, feedback, partnership inquiries."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Contact</h1>
      <p class="text-lg text-light-gray-500 dark:text-light-text mb-12">
        We typically respond within 48 hours. For bug reports, GitHub Issues is the fastest path to a fix.
      </p>

      <div class="space-y-8">
        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-accent-silver/15 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-accent-silver" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1">Email</h2>
            <p class="text-sm text-light-gray-500 dark:text-muted mb-2">General inquiries and partnership requests.</p>
            <a href="mailto:info@synctek.io" class="text-accent-silver no-underline hover:underline">info@synctek.io</a>
          </div>
        </div>

        <!-- GitHub Issues - per product -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-accent-silver/15 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-accent-silver" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1">GitHub Issues</h2>
            <p class="text-sm text-light-gray-500 dark:text-muted mb-2">Bug reports and feature requests. Fastest path to a fix.</p>
            <div class="flex flex-col gap-1.5">
              {products.map((product) => {
                const support = 'support' in product ? (product as any).support : null;
                return support?.github ? (
                  <a href={`https://github.com/${support.github}/issues`} target="_blank" rel="noopener noreferrer" class="text-accent-silver no-underline hover:underline">
                    {support.github}/issues
                    <span class="text-xs text-light-gray-500 dark:text-muted ml-1.5"> - {product.name}</span>
                  </a>
                ) : null;
              })}
            </div>
          </div>
        </div>

        <!-- Twitter -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-accent-silver/15 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-accent-silver" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1">Twitter / X</h2>
            <p class="text-sm text-light-gray-500 dark:text-muted mb-2">Quick questions and updates.</p>
            <a href="https://twitter.com/SyncTekLLC" target="_blank" rel="noopener noreferrer" class="text-accent-silver no-underline hover:underline">
              @SyncTekLLC
            </a>
          </div>
        </div>

        <!-- LinkedIn -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-accent-silver/15 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-accent-silver" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <div>
            <h2 class="font-semibold mb-1">LinkedIn</h2>
            <p class="text-sm text-light-gray-500 dark:text-muted mb-2">Company updates and professional inquiries.</p>
            <a href="https://linkedin.com/company/synctek-llc" target="_blank" rel="noopener noreferrer" class="text-accent-silver no-underline hover:underline">
              SyncTek LLC
            </a>
          </div>
        </div>
      </div>

      <!-- Product support -->
      <div class="mt-16">
        <h2 class="text-xl font-semibold mb-6">Product support</h2>
        <div class="space-y-8">
          {products.map((product) => {
            const support = 'support' in product ? product.support : null;
            if (!support) return null;
            return (
              <div class="rounded-lg border border-light-border dark:border-border-gray p-6">
                <h3 class="font-semibold mb-1" style={`color: ${product.accentColor}`}>{product.name}</h3>
                <p class="text-sm text-light-gray-500 dark:text-muted mb-4">{product.tagline}</p>
                <div class="flex flex-wrap gap-3">
                  {support.email && (
                    <a
                      href={`mailto:${support.email}`}
                      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-light-border dark:border-border-gray text-sm no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                      {support.email}
                    </a>
                  )}
                  {support.github && (
                    <a
                      href={`https://github.com/${support.github}/issues`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-light-border dark:border-border-gray text-sm no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                        <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
                      </svg>
                      GitHub Issues
                    </a>
                  )}
                  {support.docs && (
                    <a
                      href={support.docs}
                      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-light-border dark:border-border-gray text-sm no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      Docs
                    </a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
