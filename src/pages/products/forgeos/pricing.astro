---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionDivider from '../../../components/SectionDivider.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'ForgeOS Pricing',
  url: 'https://synctek.io/products/forgeos/pricing',
  description:
    'ForgeOS pricing: Pro $49/month, Team $29/seat/month, Enterprise custom. 14-day free trial. No credit card required.',
  mainEntity: {
    '@type': 'Product',
    name: 'ForgeOS',
    description:
      'The governance OS for agentic teams — constitutional enforcement, Ed25519-signed audit trail, and circuit breakers for AI agents in production.',
    brand: {
      '@type': 'Brand',
      name: 'SyncTek LLC',
    },
    offers: [
      {
        '@type': 'Offer',
        name: 'Free',
        price: '0',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/forgeos/pricing',
        description: 'Free tier: 1,000 API calls/month, 20 req/min. Gate enforcement, Ed25519-signed ledger, forge CLI.',
      },
      {
        '@type': 'Offer',
        name: 'Pro',
        price: '49.00',
        priceCurrency: 'USD',
        billingIncrement: 'Month',
        priceValidUntil: '2026-12-31',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/forgeos/pricing',
        description:
          '50,000 API calls/month. Gate enforcement, signed ledger, 21 MCP tools, EU AI Act artifacts, email support.',
      },
      {
        '@type': 'Offer',
        name: 'Team',
        price: '29.00',
        priceCurrency: 'USD',
        unitText: 'per seat per month',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/forgeos/pricing',
        description:
          'Team plan: $29/seat/month, 3-seat minimum. 200,000 API calls, shared projects, role-based access.',
      },
      {
        '@type': 'Offer',
        name: 'Enterprise',
        priceSpecification: {
          '@type': 'PriceSpecification',
          description: 'Custom pricing — contact us',
        },
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/forgeos/pricing',
        description:
          'Dedicated tenant. 4h SLA. Security questionnaire support. DPA on request.',
      },
    ],
  },
};

const faqItems = [
  {
    question: 'Does the trial require a credit card?',
    answer:
      'No. The 14-day trial is full Pro-tier access with no credit card required. If you decide not to continue, your data is retained for 30 days after trial expiry, then deleted.',
  },
  {
    question: 'What counts as an API call?',
    answer:
      'Each call to a ForgeOS MCP tool (gate-check, delegation-validate, audit-query, etc.) counts as one API call. Ledger writes triggered by those calls do not count separately.',
  },
  {
    question: 'What is the Enterprise Compliance tier?',
    answer:
      'EU data residency, extended audit retention, and dedicated infrastructure are features we are actively building. Enterprise Compliance pricing is available on request — contact us to discuss your requirements and timeline.',
  },
  {
    question: 'Can I switch plans mid-cycle?',
    answer:
      'Yes. Upgrades take effect immediately. Downgrades take effect at the next billing cycle. No penalties, no lock-in on the Pro plan.',
  },
  {
    question: 'What is included in the EU AI Act compliance bundle?',
    answer:
      'The compliance bundle includes: hash-chained Ed25519-signed ledger export (Article 12), gate artifact chain for conformity assessment (Article 17), circuit breaker + kill switch documentation (Article 14), and A2A Agent Card (Article 13 partial). Enterprise tier adds legal mapping documentation.',
  },
  {
    question: 'Is the governance engine open source?',
    answer:
      'Open-sourcing the governance engine core is planned. The CLI client is MIT-licensed. The hosted API and AI components are proprietary. We will announce the open-source timeline publicly.',
  },
  {
    question: 'What is included in the Free plan?',
    answer:
      'The Free plan includes gate enforcement, Ed25519-signed ledger, forge CLI, FTI badge embeds, 5 FTI scores/day, and SharedMind in read-only mode. You get 1,000 API calls/month at 20 req/min. MCP tools are limited to 5 of 21. Upgrade to Pro for the full suite.',
  },
  {
    question: 'How does FTI scoring work with my plan?',
    answer:
      'FTI (ForgeOS Trust Index) is bundled with every ForgeOS plan. Free plans include 5 FTI scores/day. Pro, Team, and Enterprise plans include unlimited scoring, recommendations, and comparative analysis across all 8 dimensions (security, maintainability, documentation, community health, supply chain, improvement velocity, governance, and operational). If you need FTI API access without a ForgeOS subscription — for AI agents, CI/CD pipelines, or external tooling — a standalone metered API is available at $0.003/score, $0.005/recommendation, and $0.008/comparison. The GET /v1/methodology endpoint is free and public.',
  },
];

type FeatureValue = boolean | string;

interface FeatureRow {
  feature: string;
  free: FeatureValue;
  pro: FeatureValue;
  team: FeatureValue;
  enterprise: FeatureValue;
  note?: string;
}

const comparisonRows: FeatureRow[] = [
  { feature: 'API calls / month', free: '1,000', pro: '50,000', team: '200,000', enterprise: 'Dedicated' },
  { feature: 'Seats', free: '1', pro: '1', team: '3+ (min.)', enterprise: 'Unlimited' },
  { feature: 'Gate enforcement', free: true, pro: true, team: true, enterprise: true },
  { feature: 'Ed25519-signed ledger', free: true, pro: true, team: true, enterprise: true },
  { feature: '21 MCP governance tools', free: '5 of 21', pro: true, team: true, enterprise: true },
  { feature: 'forge CLI (18 command groups)', free: true, pro: true, team: true, enterprise: true },
  { feature: 'FTI scoring (8 dimensions)', free: '5/day', pro: 'Unlimited', team: 'Unlimited', enterprise: 'Unlimited' },
  { feature: 'FTI recommendations', free: false, pro: true, team: true, enterprise: true },
  { feature: 'FTI comparative analysis', free: false, pro: true, team: true, enterprise: true },
  { feature: 'SharedMind (institutional memory)', free: 'Read-only', pro: true, team: true, enterprise: true },
  { feature: 'Self-approval prevention', free: true, pro: true, team: true, enterprise: true },
  { feature: 'Circuit breakers', free: true, pro: true, team: true, enterprise: true },
  { feature: 'Human-in-the-loop gates', free: true, pro: true, team: true, enterprise: true },
  { feature: 'EU AI Act artifacts (Art. 12, 17)', free: false, pro: true, team: true, enterprise: true },
  { feature: 'A2A Agent Card', free: false, pro: true, team: true, enterprise: true },
  { feature: 'Forensic violation scanner', free: false, pro: true, team: true, enterprise: true },
  { feature: 'Email support', free: false, pro: true, team: true, enterprise: true },
  { feature: 'Team dashboard', free: false, pro: false, team: true, enterprise: true },
  { feature: 'Shared projects', free: false, pro: false, team: true, enterprise: true },
  { feature: 'Role-based access control', free: false, pro: false, team: true, enterprise: true },
  { feature: '4h SLA + custom SLA', free: false, pro: false, team: false, enterprise: true },
  { feature: 'Security questionnaire support', free: false, pro: false, team: false, enterprise: true },
  { feature: 'DPA on request', free: false, pro: false, team: false, enterprise: true },
  { feature: 'EU data residency', free: false, pro: false, team: false, enterprise: 'Compliance tier — contact us', note: 'Not yet available — contact us' },
  { feature: 'Extended audit retention', free: false, pro: false, team: false, enterprise: 'Compliance tier — contact us', note: 'Not yet available — contact us' },
  { feature: 'Dedicated infrastructure', free: false, pro: false, team: false, enterprise: true },
];

function renderValue(val: FeatureValue) {
  if (val === true) return { type: 'check' };
  if (val === false) return { type: 'x' };
  return { type: 'text', text: val };
}
---

<BaseLayout
  title="ForgeOS Pricing — Pro $49, Team $29/seat, Enterprise Custom"
  description="14-day free trial, no credit card. Pro: $49/month. Team: $29/seat/month (3-seat min). Enterprise: custom pricing with dedicated tenant and SLA. Gate enforcement, signed ledger, 21 MCP tools, EU AI Act artifacts."
  jsonLd={jsonLd}
