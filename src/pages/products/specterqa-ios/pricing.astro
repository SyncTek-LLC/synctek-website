---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionDivider from '../../../components/SectionDivider.astro';
import product from '../../../data/products/specterqa-ios';

const accentColor = product.accentColor;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'SpecterQA iOS Pricing',
  url: 'https://synctek.io/products/specterqa-ios/pricing',
  description:
    'SpecterQA iOS pricing: Trial free, Indie $29/mo, Pro $99/mo ($990/yr), Team $299/mo ($2,990/yr), Enterprise custom. BYOK — your API key, your data.',
  mainEntity: {
    '@type': 'Product',
    name: 'SpecterQA iOS',
    description:
      'AI-native iOS testing via MCP — record once, replay free. 19 MCP tools, Maestro-compatible, BYOK.',
    brand: { '@type': 'Brand', name: 'SyncTek LLC' },
    offers: [
      {
        '@type': 'Offer',
        name: 'Trial',
        price: '0',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/specterqa-ios/pricing',
        description: 'Trial: 1 simulator, 3 runs/session. No credit card.',
      },
      {
        '@type': 'Offer',
        name: 'Indie',
        price: '29.00',
        priceCurrency: 'USD',
        billingIncrement: 'Month',
        priceValidUntil: '2026-12-31',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/specterqa-ios/pricing',
        description: 'Indie: 1 simulator, unlimited runs. BYOK required.',
      },
      {
        '@type': 'Offer',
        name: 'Pro',
        price: '99.00',
        priceCurrency: 'USD',
        billingIncrement: 'Month',
        priceValidUntil: '2026-12-31',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/specterqa-ios/pricing',
        description: 'Pro: 4 simulators, parallel CI, unlimited runs. BYOK required. $990/yr annual.',
      },
      {
        '@type': 'Offer',
        name: 'Team',
        price: '299.00',
        priceCurrency: 'USD',
        billingIncrement: 'Month',
        priceValidUntil: '2026-12-31',
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/specterqa-ios/pricing',
        description: 'Team: 10 simulators, parallel CI, priority support. BYOK required. $2,990/yr annual.',
      },
      {
        '@type': 'Offer',
        name: 'Enterprise',
        priceSpecification: {
          '@type': 'PriceSpecification',
          description: 'Custom pricing — contact us',
        },
        availability: 'https://schema.org/InStock',
        url: 'https://synctek.io/products/specterqa-ios/pricing',
        description: 'Enterprise: unlimited simulators, SLA, dedicated support, custom contracts.',
      },
    ],
  },
};

type FeatureValue = boolean | string;

interface FeatureRow {
  feature: string;
  trial: FeatureValue;
  indie: FeatureValue;
  pro: FeatureValue;
  team: FeatureValue;
  enterprise: FeatureValue;
  note?: string;
}

const comparisonRows: FeatureRow[] = [
  { feature: 'Simulators', trial: '1', indie: '1', pro: '4', team: '10', enterprise: 'Unlimited' },
  { feature: 'Runs / session limit', trial: '3', indie: 'Unlimited', pro: 'Unlimited', team: 'Unlimited', enterprise: 'Unlimited' },
  { feature: 'Parallel CI', trial: false, indie: false, pro: true, team: true, enterprise: true },
  { feature: 'All 19 MCP tools', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'Record & replay (YAML)', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'Maestro YAML compat', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'Accessibility audit', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'GitHub Actions integration', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'BYOK (Anthropic key)', trial: 'Required', indie: 'Required', pro: 'Required', team: 'Required', enterprise: 'Required' },
  { feature: 'CI replay (no AI cost)', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'Dark / light mode toggle', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'WebView element query', trial: true, indie: true, pro: true, team: true, enterprise: true },
  { feature: 'Priority support', trial: false, indie: false, pro: false, team: true, enterprise: true },
  { feature: 'SLA', trial: false, indie: false, pro: false, team: false, enterprise: true },
  { feature: 'Custom contracts / DPA', trial: false, indie: false, pro: false, team: false, enterprise: true },
  { feature: 'Dedicated support channel', trial: false, indie: false, pro: false, team: false, enterprise: true },
  { feature: 'Annual billing (save 17%)', trial: false, indie: false, pro: true, team: true, enterprise: 'Custom' },
];

const faqItems = [
  {
    question: 'What is BYOK?',
    answer:
      'BYOK stands for "Bring Your Own Key." You supply your own Anthropic API key for the AI-powered record phase. SyncTek never stores, proxies, or sees your key. Your AI spend goes directly to Anthropic — not through us. Replay runs are 100% deterministic and never call the Anthropic API, so CI costs zero AI tokens.',
  },
  {
    question: 'What simulators are supported?',
    answer:
      'SpecterQA iOS works with any iOS simulator available via Xcode on macOS. You control which device types and iOS versions are booted — iPhone, iPad, any Xcode-supported iOS version. Physical device testing is not currently supported. A macOS runner with Xcode 15 or later is required.',
  },
  {
    question: 'How does licensing work?',
    answer:
      'SpecterQA iOS is licensed under the Elastic License 2.0 (ELv2). It is free for internal use — building and testing your own apps. You cannot redistribute it as a managed service or competing testing product without a commercial agreement. The CLI is open source; the commercial subscription unlocks more simulators and parallel CI.',
  },
  {
    question: 'Does the trial require a credit card?',
    answer:
      'No. The Trial tier is free with no credit card required. You get 1 simulator and 3 runs per session. You still need your own Anthropic API key for the record phase (BYOK). Install via pip and run immediately.',
  },
  {
    question: 'What counts as a "run"?',
    answer:
      'A run is one invocation of `specterqa-ios run` or one MCP-triggered recording session. Trial limits are per session (process lifetime). Indie, Pro, Team, and Enterprise tiers have no run limits — only simulator concurrency limits.',
  },
  {
    question: 'Can I use SpecterQA iOS in CI/CD?',
    answer:
      'Yes. Replay files (YAML) recorded once can be replayed in CI without any Anthropic API calls. The `specterqa-ios ci` command accepts a directory of replay files and runs them sequentially (Trial/Indie) or in parallel (Pro/Team/Enterprise). GitHub Actions integration is included at all tiers.',
  },
  {
    question: 'What is the annual discount?',
    answer:
      'Pro annual is $990/yr (vs $1,188/yr monthly — save $198). Team annual is $2,990/yr (vs $3,588/yr monthly — save $598). Annual billing is available on Pro and Team tiers. Enterprise pricing is fully custom.',
  },
  {
    question: 'Is Maestro YAML migration free?',
    answer:
      'Yes. Existing Maestro YAML files work natively with SpecterQA iOS — `tapOn`, `inputText`, `assertVisible`, `assertNotVisible`, and `waitFor` are understood without modification. No migration tooling required. Mix Maestro shorthand and SpecterQA native syntax in the same file.',
  },
];

function renderValue(val: FeatureValue) {
  if (val === true) return { type: 'check' };
  if (val === false) return { type: 'x' };
  return { type: 'text', text: val };
}
