          </li>
          <li class="flex items-start gap-2 text-[#E6EDF3]">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Custom contracts
          </li>
          <li class="flex items-start gap-2 text-[#E6EDF3]">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Dedicated support
          </li>
        </ul>
      </div>

    </div>
  </section>

  <SectionDivider />

  <!-- Comparison table -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-[#E6EDF3] tracking-tight">Full feature comparison</h2>
    </div>

    <div class="overflow-x-auto rounded-xl" style="border: 1px solid #1F1F1F;">
      <table class="w-full text-sm min-w-[700px]">
        <thead>
          <tr style="background: #111111; border-bottom: 1px solid #1F1F1F;">
            <th class="text-left px-5 py-4 font-semibold text-[#8B949E] w-48">Feature</th>
            <th class="text-center px-4 py-4 font-semibold text-[#8B949E]">Trial</th>
            <th class="text-center px-4 py-4 font-semibold text-[#8B949E]">Indie</th>
            <th class="text-center px-4 py-4 font-semibold whitespace-nowrap" style={`color: ${accentColor};`}>Pro</th>
            <th class="text-center px-4 py-4 font-semibold text-[#8B949E]">Team</th>
            <th class="text-center px-4 py-4 font-semibold text-[#8B949E]">Enterprise</th>
          </tr>
        </thead>
        <tbody>
          {comparisonRows.map((row, i) => {
            const tVal = renderValue(row.trial);
            const iVal = renderValue(row.indie);
            const pVal = renderValue(row.pro);
            const tmVal = renderValue(row.team);
            const eVal = renderValue(row.enterprise);

            return (
              <tr style={`background: ${i % 2 === 0 ? '#0D0D0D' : '#111111'}; border-bottom: 1px solid #1A1A1A;`}>
                <td class="px-5 py-3.5 text-[#E6EDF3] font-medium">
                  {row.feature}
                  {row.note && <span class="block text-xs text-[#8B949E] font-normal mt-0.5">{row.note}</span>}
                </td>
                <td class="px-4 py-3.5 text-center">
                  {tVal.type === 'check' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-label="Included"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {tVal.type === 'x' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#484F58" viewBox="0 0 24 24" stroke-width="2" aria-label="Not included"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>}
                  {tVal.type === 'text' && <span class="text-[#9CA3AF] text-xs">{tVal.text}</span>}
                </td>
                <td class="px-4 py-3.5 text-center">
                  {iVal.type === 'check' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-label="Included"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {iVal.type === 'x' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#484F58" viewBox="0 0 24 24" stroke-width="2" aria-label="Not included"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>}
                  {iVal.type === 'text' && <span class="text-[#9CA3AF] text-xs">{iVal.text}</span>}
                </td>
                <td class="px-4 py-3.5 text-center" style={`background: rgba(188,140,255,0.04);`}>
                  {pVal.type === 'check' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-label="Included"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {pVal.type === 'x' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#484F58" viewBox="0 0 24 24" stroke-width="2" aria-label="Not included"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>}
                  {pVal.type === 'text' && <span class="text-xs" style={`color: ${accentColor};`}>{pVal.text}</span>}
                </td>
                <td class="px-4 py-3.5 text-center">
                  {tmVal.type === 'check' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-label="Included"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {tmVal.type === 'x' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#484F58" viewBox="0 0 24 24" stroke-width="2" aria-label="Not included"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>}
                  {tmVal.type === 'text' && <span class="text-[#9CA3AF] text-xs">{tmVal.text}</span>}
                </td>
                <td class="px-4 py-3.5 text-center">
                  {eVal.type === 'check' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-label="Included"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {eVal.type === 'x' && <svg class="w-4 h-4 mx-auto" fill="none" stroke="#484F58" viewBox="0 0 24 24" stroke-width="2" aria-label="Not included"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>}
                  {eVal.type === 'text' && <span class="text-[#9CA3AF] text-xs">{eVal.text}</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <SectionDivider />

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <p class="text-xs font-semibold tracking-[0.12em] uppercase mb-3" style={`color: ${accentColor};`}>FAQ</p>
      <h2 class="text-3xl font-bold text-[#E6EDF3] tracking-tight" style="letter-spacing: -0.02em;">
        Common questions
      </h2>
    </div>

    <div class="space-y-4">
      {faqItems.map((item) => (
        <details class="group rounded-xl overflow-hidden" style="background: #111111; border: 1px solid #1F1F1F;">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none select-none">
            <span class="font-medium text-[#E6EDF3] pr-4">{item.question}</span>
            <svg
              class="w-4 h-4 flex-shrink-0 text-[#8B949E] transition-transform duration-200 group-open:rotate-45"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="px-6 pb-5">
            <p class="text-sm text-[#9CA3AF] leading-relaxed">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- Bottom CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl font-bold text-[#E6EDF3] mb-4" style="letter-spacing: -0.02em;">
      Ready to let your agent write the tests?
    </h2>
    <p class="text-[#9CA3AF] mb-8 max-w-xl mx-auto">
      Start free — no credit card. Bring your own Anthropic key. Record once, replay free in CI forever.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="#plans"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-md font-semibold text-white no-underline transition-all duration-150"
        style={`background: ${accentColor};`}
        onmouseover="this.style.opacity='0.9'"
        onmouseout="this.style.opacity='1'"
      >
        View plans
      </a>
      <a
        href="mailto:sales@synctek.io"
        class="inline-flex items-center justify-center px-8 py-3.5 rounded-md font-semibold text-[#E6EDF3] no-underline transition-all"
        style="border: 1px solid #30363D;"
        onmouseover="this.style.borderColor='#8B949E'; this.style.background='rgba(255,255,255,0.04)'"
        onmouseout="this.style.borderColor='#30363D'; this.style.background='transparent'"
      >
        Talk to sales
      </a>
    </div>
  </section>
</BaseLayout>
