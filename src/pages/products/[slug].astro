  <!-- Client-side FTI score hydration: sole source of score data.
       Runs immediately (is:inline) so scores appear without a stale-SSR flash.
       The card renders with a loading state and is populated only from this fetch. -->
  <script is:inline>
    (function () {
      var card = document.getElementById('fti-score-card');
      if (!card) return;

      var apiUrl = card.getAttribute('data-fti-api-url');
      if (!apiUrl) return;

      var dimensionLabels = {
        security: 'Security',
        maintainability: 'Maintainability',
        documentation: 'Documentation',
        community_health: 'Community',
        community: 'Community',
        supply_chain: 'Supply Chain',
        improvement_velocity: 'Velocity',
        operational: 'Operational',
        governance: 'Governance',
      };

      function scoreColor(score) {
        if (score >= 80) return 'text-[#22c55e]';
        if (score >= 60) return 'text-[#6366f1]';
        if (score >= 40) return 'text-[#f59e0b]';
        return 'text-[#ef4444]';
      }

      function hideLoading() {
        var el = document.getElementById('fti-loading');
        if (el) el.style.display = 'none';
      }

      fetch(apiUrl, { headers: { Accept: 'application/json' } })
        .then(function (res) {
          if (!res.ok) throw new Error('API returned ' + res.status);
          return res.json();
        })
        .then(function (data) {
          hideLoading();

          // Update composite score row
          var compositeRow = document.getElementById('fti-composite-row');
          var compositeSpan = document.getElementById('fti-composite-score');
          var unavailableEl = document.getElementById('fti-score-unavailable');

          if (typeof data.composite_score === 'number' && compositeRow && compositeSpan) {
            compositeSpan.textContent = data.composite_score.toFixed(1);
            compositeRow.style.display = '';
            if (unavailableEl) unavailableEl.style.display = 'none';
          } else if (unavailableEl) {
            unavailableEl.style.display = '';
          }

          // Update dimensional scores
          var dimensionsContainer = document.getElementById('fti-dimensions');
          if (data.dimensions && typeof data.dimensions === 'object' && dimensionsContainer) {
            var entries = Object.entries(data.dimensions);
            if (entries.length > 0) {
              dimensionsContainer.innerHTML = entries
                .map(function (entry) {
                  var key = entry[0];
                  var score = entry[1];
                  var label = dimensionLabels[key] || key;
                  var color = scoreColor(score);
                  return '<div class="flex flex-col gap-0.5 min-w-[72px]" data-fti-dim="' + key + '">'
                    + '<span class="text-xs text-gray-400 uppercase tracking-wider whitespace-nowrap">' + label + '</span>'
                    + '<span class="' + color + ' text-lg font-bold fti-dim-value">' + score.toFixed(1) + '</span>'
                    + '</div>';
                })
                .join('');
              dimensionsContainer.style.display = '';
            }
          }
        })
        .catch(function () {
          hideLoading();
          // API unreachable - show unavailable message
          var compositeRow = document.getElementById('fti-composite-row');
          var unavailableEl = document.getElementById('fti-score-unavailable');
          if (compositeRow) compositeRow.style.display = 'none';
          if (unavailableEl) unavailableEl.style.display = '';
        });
    })();
  </script>

