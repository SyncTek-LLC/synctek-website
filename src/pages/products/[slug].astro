---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getCollection } from 'astro:content';
import specterqa from '../../data/products/specterqa';
import forgeos from '../../data/products/forgeos';

// Build all product pages from data
const products: Record<string, typeof specterqa | typeof forgeos> = {
  specterqa,
  forgeos,
};

export function getStaticPaths() {
  return [
    { params: { slug: 'specterqa' } },
    { params: { slug: 'forgeos' } },
  ];
}

const { slug } = Astro.params;
const product = products[slug!];

if (!product) {
  return Astro.redirect('/404');
}

// Get related blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.product === slug);
const relatedPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function getReadingTime(text: string): string {
  const wpm = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wpm);
  return `${minutes} min read`;
}

const hasVersion = 'version' in product && product.version;
const hasPypi = 'distribution' in product && 'pypi' in (product as typeof specterqa).distribution;

const hasPricing = 'pricing' in product && (product as typeof forgeos).pricing && (product as typeof forgeos).pricing!.length > 0;
const lowestPrice = hasPricing
  ? (() => {
      const raw = (product as typeof forgeos).pricing![0].price;
      // Extract numeric value from price strings like "$49/mo"
      const match = raw.replace(/,/g, '').match(/[\d.]+/);
      return match ? match[0] : '0';
    })()
  : '0';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  offers: {
    '@type': 'Offer',
    price: lowestPrice,
    priceCurrency: 'USD',
  },
  ...(hasVersion ? { softwareVersion: (product as typeof specterqa).version } : {}),
  ...(hasPypi ? { downloadUrl: `https://pypi.org/project/${(product as typeof specterqa).distribution.pypi}/` } : {}),
  license: product.license === 'MIT' ? 'https://opensource.org/licenses/MIT' : undefined,
};

const featureIcons: Record<string, string> = {
  eye: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  user: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  workflow: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  plug: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
};

const ctaType = ('ctaType' in product ? product.ctaType : undefined) as string | undefined;
const loginUrl = 'loginUrl' in product ? product.loginUrl : undefined;
const support = 'support' in product ? product.support : undefined;
const fti = 'fti' in product ? (product as any).fti as Record<string, unknown> : undefined;

// FTI derived values — computed in frontmatter to avoid generic-type parse errors in JSX
const ftiShieldBadgeUrl = fti && 'shieldBadgeUrl' in fti ? fti.shieldBadgeUrl as string : undefined;
const ftiFlatBadgeUrl = fti && 'flatBadgeUrl' in fti ? fti.flatBadgeUrl as string : undefined;
const ftiBadgeUrl = fti && !ftiShieldBadgeUrl && 'badgeUrl' in fti ? fti.badgeUrl as string : undefined;
const ftiTrustProfileUrl = fti ? fti.trustProfileUrl as string : undefined;

type FtiScore = { key: string; label: string; value: number; colorClass: string };
const ftiScores: FtiScore[] = (() => {
  if (!fti || !('scores' in fti) || !fti.scores) return [];
  const raw = fti.scores as Record<string, number>;
  const labels: Record<string, string> = {
    security: 'Security',
    supplyChain: 'Supply Chain',
    supply_chain: 'Supply Chain',
    documentation: 'Documentation',
    community: 'Community',
    community_health: 'Community',
    maintainability: 'Maintainability',
    improvement_velocity: 'Velocity',
    operational: 'Operational',
    governance: 'Governance',
  };
  return Object.entries(raw).map(([key, value]) => ({
    key,
    label: labels[key] ?? key,
    value,
    colorClass: value >= 80 ? 'text-[#3FB950]' : value >= 60 ? 'text-warning-amber' : 'text-error-red',
  }));
})();

// Fetch live FTI scores at build time from the ForgeOS Trust Index API.
// The API returns a TrustProfile: { composite_score: number, dimensions: Record<string, number>, ... }
let liveFtiScores: FtiScore[] = [];
let ftiCompositeScore: number | null = null;
const ftiApiUrl = fti && 'apiScoreUrl' in fti ? fti.apiScoreUrl as string : undefined;
if (ftiApiUrl) {
  try {
    const res = await fetch(ftiApiUrl, {
      headers: { 'Accept': 'application/json' },
      signal: AbortSignal.timeout(5000),
    });
    if (res.ok) {
      const data = await res.json();
      const dimensionLabels: Record<string, string> = {
        security: 'Security',
        maintainability: 'Maintainability',
        documentation: 'Documentation',
        community_health: 'Community',
        community: 'Community',
        supply_chain: 'Supply Chain',
        improvement_velocity: 'Velocity',
        operational: 'Operational',
        governance: 'Governance',
      };
      // Capture composite score from TrustProfile.composite_score
      if (typeof data.composite_score === 'number') {
        ftiCompositeScore = data.composite_score;
      }
      // API returns dimensions as Record<string, number> (flat dict of scores)
      if (data.dimensions && typeof data.dimensions === 'object') {
        liveFtiScores = Object.entries(data.dimensions as Record<string, number>).map(([key, score]) => ({
          key,
          label: dimensionLabels[key] ?? key,
          value: typeof score === 'number' ? score : 0,
          colorClass: score >= 80 ? 'text-[#3FB950]' : score >= 60 ? 'text-warning-amber' : 'text-error-red',
        }));
      }
    }
  } catch (e) {
    // Build-time fetch failed — fall back to static scores if present
    console.warn('FTI API fetch failed at build time:', e);
  }
}
// Use live scores if available, fall back to static
const finalFtiScores = liveFtiScores.length > 0 ? liveFtiScores : ftiScores;
---

<BaseLayout
  title={product.name}
  description={product.tagline}
  ogImage={slug === 'forgeos' ? '/images/forgeos-hero-nb2.png' : undefined}
  jsonLd={jsonLd}
>
  <!-- Product header -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(188,140,255,0.08),transparent)]"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">{product.name}</h1>
      <p class="text-lg text-light-gray-500 dark:text-light-text mb-6">{product.tagline}</p>

      <!-- Badges -->
      <div class="flex flex-wrap items-center gap-3 mb-8">
        {hasVersion && (
          <Badge text={`v${(product as typeof specterqa).version}`} variant="blue" size="md" />
        )}
        <Badge text={product.license} variant="purple" size="md" />
        <Badge text={product.status === 'launched' ? 'Launched' : product.status} variant="silver" size="md" />
        <Badge text={product.type} variant="gray" size="md" />
      </div>

      <!-- FTI Trust Score Card -->
      {fti && (
        <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 mb-8 max-w-2xl">
          <!-- Header row: badges + label -->
          <div class="flex flex-wrap items-center gap-4 mb-5">
            <div class="flex items-center gap-3">
              {ftiShieldBadgeUrl && (
                <img
                  src={ftiShieldBadgeUrl}
                  alt="ForgeOS Trust Index shield badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
              {ftiBadgeUrl && (
                <img
                  src={ftiBadgeUrl}
                  alt="ForgeOS Trust Index badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
              {ftiFlatBadgeUrl && (
                <img
                  src={ftiFlatBadgeUrl}
                  alt="ForgeOS Trust Index flat badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
            </div>
            {ftiTrustProfileUrl && (
              <a
                href={ftiTrustProfileUrl}
                class="text-sm font-medium text-light-gray-500 dark:text-muted hover:text-light-gray-700 dark:hover:text-light-text no-underline transition-colors"
              >
                Verified by ForgeOS Trust Index &rarr;
              </a>
            )}
          </div>

          <!-- Composite score (live API only) -->
          {ftiCompositeScore !== null && (
            <div class="flex items-baseline gap-2 mb-4">
              <span class="text-3xl font-bold">{ftiCompositeScore.toFixed(1)}</span>
              <span class="text-sm text-gray-400">/ 100</span>
            </div>
          )}

          <!-- Dimensional score breakdown -->
          {finalFtiScores.length > 0 && (
            <div class="flex flex-wrap gap-x-6 gap-y-3">
              {finalFtiScores.map((score) => (
                <div class="flex flex-col gap-0.5 min-w-[72px]">
                  <span class="text-xs text-gray-400 uppercase tracking-wider whitespace-nowrap">
                    {score.label}
                  </span>
                  <span class:list={['text-lg font-bold', score.colorClass]}>
                    {score.value.toFixed(1)}
                  </span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        {ctaType === 'login' && loginUrl && (
          <>
            <a
              href={loginUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 rounded-lg font-semibold no-underline transition-colors"
              style={`background: ${product.accentColor}; color: #0D1117;`}
            >
              Get Started
            </a>
            <a
              href="#overview"
              class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
            >
              Learn more
            </a>
          </>
        )}
        {ctaType === 'install' && (
          <>
            <a
              href="#quickstart"
              class="inline-flex items-center px-6 py-3 rounded-lg bg-accent-silver text-obsidian font-semibold no-underline hover:bg-accent-silver-hover transition-colors"
            >
              Get Started
            </a>
            {'distribution' in product && 'github' in (product as typeof specterqa).distribution && (
              <a
                href={`https://github.com/${(product as typeof specterqa).distribution.github}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
              >
                <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
                </svg>
                View on GitHub
              </a>
            )}
          </>
        )}
        {ctaType === 'coming-soon' && (
          <span class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold text-light-gray-500 dark:text-muted">
            Coming soon
          </span>
        )}
      </div>
    </div>

    <!-- ForgeOS product hero image -->
    {slug === 'forgeos' && (
      <div class="mt-12 rounded-xl overflow-hidden" style="border: 1px solid #1F1F1F;">
        <img
          src="/images/forgeos-hero-nb2.png"
          alt="ForgeOS trust score dashboard visualization"
          class="w-full h-auto block"
          style="max-height: 420px; object-fit: cover; object-position: center top;"
          loading="lazy"
        />
      </div>
    )}
  </section>

  <SectionDivider />

  <!-- Overview -->
  <section id="overview" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Overview</h2>
    <div class="prose max-w-3xl text-light-gray-500 dark:text-light-text">
      {product.overview.split('\n\n').map((paragraph: string) => (
        <p>{paragraph.trim()}</p>
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-8">Features</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {product.features.map((feature: { title: string; description: string; icon: string }) => (
        <div class="rounded-lg border border-light-border dark:border-border-gray p-6">
          <div class="w-10 h-10 rounded-lg bg-accent-purple/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={featureIcons[feature.icon] || featureIcons['code']} />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">{feature.title}</h3>
          <p class="text-sm text-light-gray-500 dark:text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  {'quickstart' in product && (product as typeof specterqa).quickstart && (
    <>
      <SectionDivider />
      <section id="quickstart" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-8">Quick start</h2>
        <div class="max-w-2xl space-y-4">
          {(product as typeof specterqa).quickstart.map((step: { command: string; description: string }, i: number) => (
            <div class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-silver/15 text-accent-silver text-sm font-semibold flex items-center justify-center">
                {i + 1}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-light-gray-500 dark:text-muted mb-2">{step.description}</p>
                <div class="rounded-lg bg-dark-surface dark:bg-dark-surface p-3 font-mono text-sm text-terminal-white overflow-x-auto">
                  <code>$ {step.command}</code>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  {'pricing' in product && (product as typeof forgeos).pricing && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-6">Pricing</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl">
          {(product as typeof forgeos).pricing!.map((tier: { tier: string; price: string; description: string }) => (
            <div class="rounded-lg border border-light-border dark:border-border-gray p-6">
              <h3 class="font-semibold mb-1">{tier.tier}</h3>
              <p class="text-xl font-bold mb-2" style={`color: ${product.accentColor}`}>{tier.price}</p>
              <p class="text-sm text-light-gray-500 dark:text-muted">{tier.description}</p>
            </div>
          ))}
        </div>
        <div class="mt-6">
          <a href={`/products/${slug}/pricing`} class="text-sm font-medium no-underline hover:underline" style={`color: ${product.accentColor}`}>
            Full pricing details &rarr;
          </a>
        </div>
      </section>
    </>
  )}

  {'costs' in product && (product as typeof specterqa).costs && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-6">Cost transparency</h2>
        <p class="text-light-gray-500 dark:text-light-text mb-6 max-w-2xl">
          Every run costs money (Anthropic API calls). We built cost control directly into the engine so there are no surprises.
        </p>
        <div class="max-w-md">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-light-border dark:border-border-gray">
                <th class="text-left py-2 font-semibold">Journey type</th>
                <th class="text-right py-2 font-semibold">Typical cost</th>
              </tr>
            </thead>
            <tbody>
              {(product as typeof specterqa).costs!.map((cost: { type: string; range: string }) => (
                <tr class="border-b border-light-border dark:border-border-gray">
                  <td class="py-2 text-light-gray-500 dark:text-muted">{cost.type}</td>
                  <td class="py-2 text-right font-mono">{cost.range}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </>
  )}

  {product.tradeoffs && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-6">Honest tradeoffs</h2>
        <ul class="space-y-3 max-w-2xl">
          {product.tradeoffs.map((tradeoff: string) => (
            <li class="flex items-start gap-3 text-light-gray-500 dark:text-light-text">
              <svg class="w-5 h-5 text-warning-amber flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              {tradeoff}
            </li>
          ))}
        </ul>
      </section>
    </>
  )}

  <SectionDivider />

  <!-- Documentation links -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Documentation</h2>
    <div class="flex flex-wrap gap-4">
      {'distribution' in product && 'github' in (product as typeof specterqa).distribution && (
        <a
          href={`https://github.com/${(product as typeof specterqa).distribution.github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
        >
          GitHub README
        </a>
      )}
      {hasPypi && (
        <a
          href={`https://pypi.org/project/${(product as typeof specterqa).distribution.pypi}/`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
        >
          PyPI
        </a>
      )}
      {support?.docs && (
        <a
          href={support.docs}
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
        >
          Docs
        </a>
      )}
    </div>
  </section>

  {support && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-6">Support</h2>
        <div class="flex flex-wrap gap-4">
          {support.email && (
            <a
              href={`mailto:${support.email}`}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {support.email}
            </a>
          )}
          {support.github && (
            <a
              href={`https://github.com/${support.github}/issues`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
              </svg>
              GitHub Issues
            </a>
          )}
          {support.docs && (
            <a
              href={support.docs}
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-light-border dark:border-border-gray text-sm font-medium no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Documentation
            </a>
          )}
        </div>
      </section>
    </>
  )}

  <!-- Related blog posts -->
  {relatedPosts.length > 0 && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-8">Related posts</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.slug}
              readingTime={getReadingTime(post.body || '')}
            />
          ))}
        </div>
      </section>
    </>
  )}
</BaseLayout>
