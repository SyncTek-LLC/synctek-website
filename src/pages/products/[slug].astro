---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getCollection } from 'astro:content';
import specterqa from '../../data/products/specterqa';
import forgeos from '../../data/products/forgeos';

// Build all product pages from data
const products: Record<string, typeof specterqa | typeof forgeos> = {
  specterqa,
  forgeos,
};

export function getStaticPaths() {
  return [
    { params: { slug: 'specterqa' } },
    { params: { slug: 'forgeos' } },
  ];
}

const { slug } = Astro.params;
const product = products[slug!];

if (!product) {
  return Astro.redirect('/404');
}

// Get related blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.product === slug);
const relatedPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function getReadingTime(text: string): string {
  const wpm = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wpm);
  return `${minutes} min read`;
}

const hasVersion = 'version' in product && product.version;
const hasPypi = 'distribution' in product && 'pypi' in (product as typeof specterqa).distribution;

const hasPricing = 'pricing' in product && (product as typeof forgeos).pricing && (product as typeof forgeos).pricing!.length > 0;
const lowestPrice = hasPricing
  ? (() => {
      const raw = (product as typeof forgeos).pricing![0].price;
      // Extract numeric value from price strings like "$49/mo"
      const match = raw.replace(/,/g, '').match(/[\d.]+/);
      return match ? match[0] : '0';
    })()
  : '0';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  offers: {
    '@type': 'Offer',
    price: lowestPrice,
    priceCurrency: 'USD',
  },
  ...(hasVersion ? { softwareVersion: (product as typeof specterqa).version } : {}),
  ...(hasPypi ? { downloadUrl: `https://pypi.org/project/${(product as typeof specterqa).distribution.pypi}/` } : {}),
  license: product.license === 'MIT' ? 'https://opensource.org/licenses/MIT' : undefined,
};

const featureIcons: Record<string, string> = {
  eye: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  user: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  workflow: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  plug: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
};

const ctaType = ('ctaType' in product ? product.ctaType : undefined) as string | undefined;
const loginUrl = 'loginUrl' in product ? product.loginUrl : undefined;
const support = 'support' in product ? product.support : undefined;
const fti = 'fti' in product ? (product as any).fti as Record<string, unknown> : undefined;

// Competitive stack positioning data (ForgeOS only)
const stackRows = slug === 'forgeos' ? [
  { layer: 'Code generation', tools: 'Cursor, Windsurf, Devin', relationship: 'They produce code. ForgeOS governs what happens to it after.' },
  { layer: 'Agent orchestration', tools: 'CrewAI, LangGraph, AutoGen', relationship: 'They route tasks. ForgeOS enforces gates, delegation rules, and audit trails.' },
  { layer: 'Observability', tools: 'LangSmith, W&B Weave', relationship: 'They record what happened. ForgeOS prevents what should not happen.' },
  { layer: 'ForgeOS', tools: 'ForgeOS', relationship: 'The enforcement layer. Between orchestration and human approval.' },
] : [];

// EU AI Act rows (ForgeOS only)
const euAiActRows = slug === 'forgeos' ? [
  { article: 'Art. 12', requirement: 'Record-keeping - immutable logs of all automated decisions', coverage: 'Hash-chained, Ed25519-signed ledger', confidence: 'Direct coverage' },
  { article: 'Art. 9', requirement: 'Risk management system - documented procedures', coverage: 'Gate enforcement, circuit breakers, violation scanner', confidence: 'Direct coverage' },
  { article: 'Art. 14', requirement: 'Human oversight - ability to halt and override', coverage: 'Human-in-the-loop gates, kill switch, circuit breaker', confidence: 'Direct coverage' },
  { article: 'Art. 17', requirement: 'Quality management system', coverage: 'Initiative + gate lifecycle', confidence: 'Direct coverage' },
  { article: 'Art. 61', requirement: 'Post-market monitoring', coverage: 'Continuous automated scanning, daily self-audit', confidence: 'Partial coverage' },
] : [];

// FTI derived values - computed in frontmatter to avoid generic-type parse errors in JSX
const ftiShieldBadgeUrl = fti && 'shieldBadgeUrl' in fti ? fti.shieldBadgeUrl as string : undefined;
const ftiFlatBadgeUrl = fti && 'flatBadgeUrl' in fti ? fti.flatBadgeUrl as string : undefined;
const ftiBadgeUrl = fti && !ftiShieldBadgeUrl && 'badgeUrl' in fti ? fti.badgeUrl as string : undefined;
const ftiTrustProfileUrl = fti ? fti.trustProfileUrl as string : undefined;

// FTI API URL used by client-side script for live hydration.
// No build-time fetch - scores render exclusively from client-side fetch to prevent
// SSR/badge divergence (badge is always live, card would show stale build-time data).
const ftiApiUrl = fti && 'apiScoreUrl' in fti ? fti.apiScoreUrl as string : undefined;
---

<BaseLayout
  title={product.name}
  description={product.tagline}
  ogImage={slug === 'forgeos' ? '/images/forgeos-hero-nb2.png' : undefined}
  jsonLd={jsonLd}
>
  <!-- Product header -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(188,140,255,0.08),transparent)]"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-2">
        {slug === 'forgeos' && (
          <img
            src="/images/forge-anvil-icon.png"
            alt="ForgeOS"
            width="80"
            height="80"
            loading="lazy"
            style="width: 80px; height: 80px; border-radius: 10px; flex-shrink: 0;"
          />
        )}
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">{product.name}</h1>
      </div>
      <p class="text-lg text-light-gray-500 dark:text-light-text mb-6">{product.tagline}</p>

      <!-- Badges -->
      <div class="flex flex-wrap items-center gap-3 mb-8">
        {hasVersion && (
          <Badge text={`v${(product as typeof specterqa).version}`} variant="blue" size="md" />
        )}
        <Badge text={product.license} variant="purple" size="md" />
        <Badge text={product.status === 'launched' ? 'Launched' : product.status} variant="silver" size="md" />
        <Badge text={product.type} variant="gray" size="md" />
      </div>

      <!-- FTI Trust Score Card -->
      {fti && (
        <div
          class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 mb-8 max-w-2xl"
          id="fti-score-card"
          data-fti-api-url={ftiApiUrl ?? ''}
        >
          <!-- Header row: badges + label -->
          <div class="flex flex-wrap items-center gap-4 mb-5">
            <div class="flex items-center gap-3">
              {ftiShieldBadgeUrl && (
                <img
                  src={ftiShieldBadgeUrl}
                  alt="ForgeOS Trust Index shield badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
              {ftiBadgeUrl && (
                <img
                  src={ftiBadgeUrl}
                  alt="ForgeOS Trust Index badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
              {ftiFlatBadgeUrl && (
                <img
                  src={ftiFlatBadgeUrl}
                  alt="ForgeOS Trust Index flat badge"
                  class="h-8"
                  loading="lazy"
                />
              )}
            </div>
            {ftiTrustProfileUrl && (
              <a
                href={ftiTrustProfileUrl}
                class="text-sm font-medium text-light-gray-500 dark:text-muted hover:text-light-gray-700 dark:hover:text-light-text no-underline transition-colors"
              >
                Verified by ForgeOS Trust Index &rarr;
              </a>
            )}
          </div>

          <!-- Loading state - shown until client-side fetch resolves -->
          <div id="fti-loading" class="text-sm text-gray-500 mb-4">Loading score...</div>
          <!-- Composite score - hidden until client-side fetch populates it -->
          <div id="fti-composite-row" class="flex items-baseline gap-2 mb-4" style="display:none">
            <span id="fti-composite-score" class="text-3xl font-bold"></span>
            <span class="text-sm text-gray-400">/ 100</span>
          </div>
          <!-- Shown only when API is unreachable at runtime -->
          <div id="fti-score-unavailable" class="text-sm text-gray-500 mb-4" style="display:none">Score unavailable</div>

          <!-- Dimensional score breakdown - hidden until client-side fetch populates it -->
          <div
            id="fti-dimensions"
            class="flex flex-wrap gap-x-6 gap-y-3"
            style="display:none"
          ></div>
        </div>
      )}

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        {ctaType === 'login' && loginUrl && (
          <>
            <a
              href={loginUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 rounded-lg font-semibold no-underline transition-colors"
              style={`background: ${product.accentColor}; color: #0D1117;`}
            >
              Get Started
            </a>
            <a
              href="#overview"
              class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
            >
              Learn more
            </a>
          </>
        )}
        {ctaType === 'install' && (
          <>
            <a
              href="#quickstart"
              class="inline-flex items-center px-6 py-3 rounded-lg bg-accent-silver text-obsidian font-semibold no-underline hover:bg-accent-silver-hover transition-colors"
            >
              Get Started
            </a>
            {'distribution' in product && 'github' in (product as typeof specterqa).distribution && (
              <a
                href={`https://github.com/${(product as typeof specterqa).distribution.github}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
              >
                <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
                </svg>
                View on GitHub
              </a>
            )}
          </>
        )}
        {ctaType === 'coming-soon' && (
          <span class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold text-light-gray-500 dark:text-muted">
            Coming soon
          </span>
        )}
      </div>
    </div>

    <!-- ForgeOS product hero image -->
    {slug === 'forgeos' && (
      <div class="mt-12 rounded-xl overflow-hidden" style="border: 1px solid #1F1F1F;">
        <img
          src="/images/forgeos-hero-nb2.png"
          alt="ForgeOS trust score dashboard visualization"
          class="w-full h-auto block"
          style="max-height: 420px; object-fit: cover; object-position: center top;"
          loading="lazy"
        />
      </div>
    )}

    {/* ForgeOS Terminal Preview */}
    {slug === 'forgeos' && (
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
        <div class="max-w-2xl mx-auto">
          <div class="mt-14">
            <div
              class="rounded-xl overflow-hidden"
              style="border: 1px solid #1F1F1F; background: #111111; box-shadow: 0 0 40px rgba(59,130,246,0.06);"
            >
              <!-- Terminal chrome -->
              <div
                class="flex items-center gap-2 px-4 py-3"
                style="background: #1A1A1A; border-bottom: 1px solid #1F1F1F;"
              >
                <div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
                <div class="w-3 h-3 rounded-full" style="background: #FEBC2E;"></div>
                <div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
                <span class="ml-2 text-xs text-[#8B949E] font-mono">forge gate status cs_a1b2c3</span>
              </div>
              <!-- Terminal content -->
              <div class="p-5 font-mono text-sm leading-relaxed" style="color: #E6EDF3;">
                <div class="text-[#8B949E]">$ <span class="text-[#E6EDF3]">forge gate status cs_a1b2c3</span></div>
                <div class="mt-3 space-y-1">
                  <div>
                    <span class="text-[#10B981]">  ✓</span>
                    <span class="text-[#E6EDF3]">  intent</span>
                    <span class="text-[#8B949E] text-xs ml-2">2026-02-25 14:32:01  [a3f2c1...]</span>
                  </div>
                  <div>
                    <span class="text-[#10B981]">  ✓</span>
                    <span class="text-[#E6EDF3]">  design</span>
                    <span class="text-[#8B949E] text-xs ml-2">2026-02-25 15:10:44  [b8e91d...]</span>
                  </div>
                  <div>
                    <span class="text-[#EF4444]">  ✗</span>
                    <span class="text-[#E6EDF3]">  implementation</span>
                    <span class="text-[#F59E0B] text-xs ml-2">PENDING - architect review required</span>
                  </div>
                </div>
                <div class="mt-4" style="border-top: 1px solid #1F1F1F; padding-top: 1rem;">
                  <span class="text-[#EF4444] font-semibold">STATUS: BLOCKED</span>
                  <div class="text-[#8B949E] text-xs mt-1">Next required: architect review + unit_test evidence</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
  </section>

  <SectionDivider />

  <!-- Overview -->
  <section id="overview" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Overview</h2>
    <div class="prose max-w-3xl text-light-gray-500 dark:text-light-text">
      {product.overview.split('\n\n').map((paragraph: string) => (
        <p>{paragraph.trim()}</p>
      ))}
    </div>
  </section>

  <SectionDivider />

  {/* ForgeOS Value Propositions */}
  {slug === 'forgeos' && (
    <>
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">WHY FORGEOS</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Enforce, don't observe -->
          <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
              style="background: rgba(59,130,246,0.10);"
            >
              <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Enforce, don't observe</h3>
            <p class="text-sm text-[#8B949E] leading-relaxed">
              Gates fire before actions execute. Policy is constitutional - defined once, enforced everywhere.
              No configuration can disable self-approval prevention.
            </p>
          </div>

          <!-- Immutable audit trail -->
          <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
              style="background: rgba(59,130,246,0.10);"
            >
              <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Immutable audit trail</h3>
            <p class="text-sm text-[#8B949E] leading-relaxed">
              Ed25519-signed, hash-chained ledger. Every agent action, every gate decision, every delegation event.
              Retroactive alteration breaks the chain - detectable in milliseconds. Auditor-ready. Designed for EU AI Act readiness.
            </p>
          </div>

          <!-- Agent-native -->
          <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
              style="background: rgba(59,130,246,0.10);"
            >
              <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Agent-native + CLI</h3>
            <p class="text-sm text-[#8B949E] leading-relaxed">
              21 governance tools over MCP (HTTP/SSE). Any MCP-compatible agent calls ForgeOS directly -
              gate-check, delegation-validate, audit-query. Plus the <code class="font-mono text-xs px-1 py-0.5 rounded" style="background: rgba(139,148,158,0.10); border: 1px solid #1F1F1F; color: #E6EDF3;">forge</code> CLI for terminal-first workflows. Framework-agnostic. No SDK required. Works with Claude, GPT, Gemini, or local models - your AI keys stay with you.
            </p>
          </div>
        </div>
      </section>
      <SectionDivider />
    </>
  )}

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-8">Features</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {product.features.map((feature: { title: string; description: string; icon: string }) => (
        <div class="rounded-lg border border-light-border dark:border-border-gray p-6">
          <div class="w-10 h-10 rounded-lg bg-accent-purple/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={featureIcons[feature.icon] || featureIcons['code']} />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">{feature.title}</h3>
          <p class="text-sm text-light-gray-500 dark:text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  {'quickstart' in product && (product as typeof specterqa).quickstart && (
    <>
      <SectionDivider />
      <section id="quickstart" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-8">Quick start</h2>
        <div class="max-w-2xl space-y-4">
          {(product as typeof specterqa).quickstart.map((step: { command: string; description: string }, i: number) => (
            <div class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-silver/15 text-accent-silver text-sm font-semibold flex items-center justify-center">
                {i + 1}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-light-gray-500 dark:text-muted mb-2">{step.description}</p>
                <div class="rounded-lg bg-dark-surface dark:bg-dark-surface p-3 font-mono text-sm text-terminal-white overflow-x-auto">
                  <code>$ {step.command}</code>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  {/* ForgeOS Trust Signals + EU AI Act Table */}
  {slug === 'forgeos' && (
    <>
      <SectionDivider />
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">TRUST SIGNALS</p>
        <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
          Governing 13 AI departments in production - including the team that built it.
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <!-- Dogfood proof -->
          <div
            class="rounded-xl p-6"
            style="background: #111111; border-left: 3px solid #3B82F6; border-top: 1px solid #1F1F1F; border-right: 1px solid #1F1F1F; border-bottom: 1px solid #1F1F1F;"
          >
            <h3 class="text-sm font-semibold text-[#E6EDF3] mb-2">Dogfooded in production</h3>
