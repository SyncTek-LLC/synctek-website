---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import RepoCard from '../components/RepoCard.astro';
import reposData from '../data/repos';
---

<BaseLayout
  title="Open Source"
  description="SyncTek's open-source projects. MIT-licensed developer tools you can fork, audit, and contribute to."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Open source</h1>
    <p class="text-lg text-light-gray-500 dark:text-light-text max-w-2xl mb-4">
      We open-source the tools developers run locally. The CLI on your machine is yours -- MIT licensed, forkable, community-driven. We are selective about what we open-source, not dogmatic. What matters is that the tool you depend on is not a black box.
    </p>
    <p class="text-light-gray-500 dark:text-light-text max-w-2xl mb-12">
      We welcome contributors at every level. Check each repo's CONTRIBUTING.md for guidelines, or start with issues labeled "good first issue."
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {reposData.repos.map((repo: any) => (
        <RepoCard
          name={repo.name}
          org={repo.org}
          description={repo.description}
          language={repo.language}
          stars={repo.stars}
          license={repo.license}
          topics={repo.topics}
          featured={repo.featured}
        />
      ))}
    </div>

    <SectionDivider />

    <div class="mt-12 text-center">
      <a
        href="https://github.com/SyncTek-LLC"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
        </svg>
        View all repos on GitHub
      </a>
    </div>
  </section>
</BaseLayout>
