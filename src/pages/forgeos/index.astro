---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionDivider from '../../components/SectionDivider.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'ForgeOS',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  description:
    'The governance OS for agentic teams — constitutional enforcement, Ed25519-signed audit trail, and circuit breakers for AI agents in production.',
  url: 'https://synctek.io/forgeos',
  offers: [
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '49.00',
      priceCurrency: 'USD',
      billingIncrement: 'Month',
      description: 'Full gate enforcement, signed ledger, MCP server, EU AI Act artifacts.',
    },
    {
      '@type': 'Offer',
      name: 'Team',
      price: '149.00',
      priceCurrency: 'USD',
      billingIncrement: 'Month',
      description: 'Pro plus team delegation rules and 200,000 API calls/month.',
    },
    {
      '@type': 'Offer',
      name: 'Enterprise',
      price: '2000.00',
      priceCurrency: 'USD',
      billingIncrement: 'Month',
      description: 'Dedicated tenant, SLA, EU data residency, compliance bundle.',
    },
  ],
  brand: {
    '@type': 'Brand',
    name: 'SyncTek LLC',
  },
};

const mcpTools = [
  {
    category: 'Enforcement',
    color: 'blue',
    tools: [
      { name: 'gate-check', description: 'Pre-execution gate validation — returns CODE_AUTHORIZED or CODE_BLOCKED with reason.' },
      { name: 'gate-approve', description: 'Record a gate approval with evidence artifact and approver attribution.' },
      { name: 'gate-status', description: 'Query current gate state for any initiative across all pathway types.' },
    ],
  },
  {
    category: 'Delegation',
    color: 'blue',
    tools: [
      { name: 'delegation-validate', description: 'Check whether an agent is authorized to perform a specific action type.' },
      { name: 'delegation-scope', description: 'Retrieve the full authority scope for a named department or agent.' },
      { name: 'violation-report', description: 'Log a governance violation to the signed ledger with classification and severity.' },
    ],
  },
  {
    category: 'Audit',
    color: 'blue',
    tools: [
      { name: 'audit-query', description: 'Query the signed ledger by initiative, agent, time range, or event type.' },
      { name: 'audit-verify', description: 'Verify the hash chain integrity of the signed ledger — detects retroactive tampering.' },
      { name: 'ledger-export', description: 'Export ledger entries as JSON for external auditors or compliance filings.' },
    ],
  },
  {
    category: 'Signals & Status',
    color: 'blue',
    tools: [
      { name: 'signal-send', description: 'Emit a typed inter-agent signal (action_request, escalation, finding, lesson).' },
      { name: 'circuit-breaker-status', description: 'Query circuit breaker state — open, closed, or half-open — with failure counts.' },
      { name: 'governance-report', description: 'Request the latest governance police report — violations, forensic findings, SLA breaches.' },
    ],
  },
];

const howItWorks = [
  {
    step: '01',
    headline: 'Define your governance constitution',
    body: 'Set up your initiative gates, delegation rules, and agent authority scopes. ForgeOS reads the constitution at runtime — no code changes required to add or update governance rules.',
  },
  {
    step: '02',
    headline: 'Agents call ForgeOS before acting',
    body: 'Your agents call the ForgeOS gate-check endpoint before any governed action. If the gate is passed and the agent is authorized, execution proceeds. If not, the action is blocked. The decision is signed and appended to the ledger in both cases.',
  },
  {
    step: '03',
    headline: 'Violations are blocked, not just recorded',
    body: 'Constitutional violations are blocked at the pre-action hook — before any external system is affected. The violation is classified, logged to the signed ledger, and surfaced in the governance report.',
  },
  {
    step: '04',
    headline: 'The ledger is your audit trail',
    body: 'Every gate decision, every delegation event, every blocked violation — hash-chained, Ed25519-signed, tamper-evident. Export to JSON for auditors. Map to EU AI Act requirements with the compliance bundle.',
  },
  {
    step: '05',
    headline: 'Circuit breakers close the blast radius',
    body: 'When agents fail, ForgeOS halts automatically at the third consecutive failure, bounds the blast radius to the configured limits, and dispatches a notification. You are informed before the failure becomes an incident.',
  },
];

const euAiActRows = [
  { article: 'Art. 12', requirement: 'Record-keeping — immutable logs of all automated decisions', coverage: 'Hash-chained, Ed25519-signed ledger', confidence: 'Direct' },
  { article: 'Art. 9', requirement: 'Risk management system — documented procedures', coverage: 'Gate enforcement, circuit breakers, violation scanner', confidence: 'Direct' },
  { article: 'Art. 14', requirement: 'Human oversight — ability to halt and override', coverage: 'Human-in-the-loop gates, kill switch, circuit breaker', confidence: 'Direct' },
  { article: 'Art. 17', requirement: 'Quality management system', coverage: 'Initiative + gate lifecycle', confidence: 'Direct' },
  { article: 'Art. 61', requirement: 'Post-market monitoring', coverage: 'Governance scanner (6h cycle), daily self-audit', confidence: 'Direct' },
  { article: 'Art. 13', requirement: 'Transparency', coverage: 'A2A Agent Cards, agent-to-human explainer', confidence: 'Partial' },
];
---

<BaseLayout
  title="ForgeOS — The Governance OS for Agentic Teams"
  description="Constitutional enforcement, Ed25519-signed audit trail, and circuit breakers for AI agents in production. 12 MCP tools. Framework-agnostic. EU AI Act-ready."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
    <!-- Blue glow behind hero -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px]"
           style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(59,130,246,0.15) 0%, transparent 70%);">
      </div>
    </div>

    <div class="relative z-10">
      <!-- Overline -->
      <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-4">
        GOVERNANCE OS
      </p>

      <!-- ForgeOS logo lockup -->
      <div class="flex items-center gap-3 mb-6">
        <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="2" y="2" width="3" height="20" rx="1" fill="#3B82F6" />
          <rect x="19" y="2" width="3" height="20" rx="1" fill="#3B82F6" />
        </svg>
        <span class="text-2xl font-bold text-[#E6EDF3]">ForgeOS</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight max-w-3xl text-[#E6EDF3]"
          style="letter-spacing: -0.02em;">
        Govern your agents.<br />
        <span style="background: linear-gradient(135deg, #3B82F6, #1D4ED8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Before they govern themselves.
        </span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-[#9CA3AF] max-w-2xl leading-relaxed">
        Constitutional enforcement, Ed25519-signed audit trail, and circuit breakers for every AI agent you run in production.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/forgeos/pricing#trial"
          class="inline-flex items-center px-6 py-3 rounded-md font-medium text-white no-underline transition-all duration-150"
          style="background: #3B82F6; font-size: 1rem;"
          onmouseover="this.style.background='#2563EB'"
          onmouseout="this.style.background='#3B82F6'"
        >
          Start 14-day trial
        </a>
        <a
          href="https://forge-dashboard-production-6bd4.up.railway.app/login"
          class="inline-flex items-center px-6 py-3 rounded-md font-medium no-underline transition-all duration-150 text-[#3B82F6]"
          style="border: 1px solid #3B82F6;"
          onmouseover="this.style.background='rgba(59,130,246,0.10)'"
          onmouseout="this.style.background='transparent'"
        >
          Open Dashboard &rarr;
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center px-6 py-3 rounded-md font-medium no-underline transition-all duration-150 text-[#E6EDF3]"
          style="border: 1px solid #1F1F1F;"
          onmouseover="this.style.borderColor='#8B949E'; this.style.background='rgba(255,255,255,0.04)'"
          onmouseout="this.style.borderColor='#1F1F1F'; this.style.background='transparent'"
        >
          See how it works &rarr;
        </a>
      </div>

      <!-- Trust signal -->
      <p class="mt-8 text-sm text-[#8B949E]">
        Used by ForgeOS to govern ForgeOS. 13 AI departments. Live in production.
      </p>

      <!-- Terminal preview -->
      <div class="mt-14 max-w-2xl">
        <div class="rounded-xl overflow-hidden" style="border: 1px solid #1F1F1F; background: #111111; box-shadow: 0 0 40px rgba(59,130,246,0.06);">
          <!-- Terminal chrome -->
          <div class="flex items-center gap-2 px-4 py-3" style="background: #1A1A1A; border-bottom: 1px solid #1F1F1F;">
            <div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
            <div class="w-3 h-3 rounded-full" style="background: #FEBC2E;"></div>
            <div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
            <span class="ml-2 text-xs text-[#8B949E] font-mono">forgeos gate-check --initiative INIT-001</span>
          </div>
          <!-- Terminal content -->
          <div class="p-5 font-mono text-sm leading-relaxed" style="color: #E6EDF3;">
            <div class="text-[#8B949E]">$ <span class="text-[#E6EDF3]">forgeos gate-check --initiative INIT-001</span></div>
            <div class="mt-3 space-y-1">
              <div>
                <span class="text-[#10B981]">  ✓</span>
                <span class="text-[#E6EDF3]">  GATE_1_SPEC_APPROVED</span>
                <span class="text-[#8B949E] text-xs ml-2">2026-02-25 14:32:01  [a3f2c1...]</span>
              </div>
              <div>
                <span class="text-[#10B981]">  ✓</span>
                <span class="text-[#E6EDF3]">  GATE_2_PRODUCT_MARKET</span>
                <span class="text-[#8B949E] text-xs ml-2">2026-02-25 15:10:44  [b8e91d...]</span>
              </div>
              <div>
                <span class="text-[#EF4444]">  ✗</span>
                <span class="text-[#E6EDF3]">  GATE_3_FEASIBILITY</span>
                <span class="text-[#F59E0B] text-xs ml-2">PENDING — no artifact found</span>
              </div>
            </div>
            <div class="mt-4" style="border-top: 1px solid #1F1F1F; padding-top: 1rem;">
              <span class="text-[#EF4444] font-semibold">STATUS: CODE_BLOCKED</span>
              <div class="text-[#8B949E] text-xs mt-1">Next required: feasibility artifact (CodeAtlas)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Three-column value props -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Enforce, don't observe -->
      <div class="rounded-xl p-6 transition-all duration-200"
           style="background: #111111; border: 1px solid #1F1F1F;">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
             style="background: rgba(59,130,246,0.10);">
          <!-- Shield icon -->
          <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Enforce, don't observe</h3>
        <p class="text-sm text-[#8B949E] leading-relaxed">
          Gates fire before actions execute. Policy is constitutional — defined once, enforced everywhere. LangSmith records what happened. ForgeOS prevents what shouldn't have.
        </p>
      </div>

      <!-- Immutable audit trail -->
      <div class="rounded-xl p-6 transition-all duration-200"
           style="background: #111111; border: 1px solid #1F1F1F;">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
             style="background: rgba(59,130,246,0.10);">
          <!-- FileCheck icon -->
          <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Immutable audit trail</h3>
        <p class="text-sm text-[#8B949E] leading-relaxed">
          Ed25519-signed, hash-chained ledger. Every agent action, every gate decision, every delegation event. Retroactive alteration breaks the chain — detectable in milliseconds.
        </p>
      </div>

      <!-- Agent-native -->
      <div class="rounded-xl p-6 transition-all duration-200"
           style="background: #111111; border: 1px solid #1F1F1F;">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
             style="background: rgba(59,130,246,0.10);">
          <!-- Terminal icon -->
          <svg class="w-5 h-5" fill="none" stroke="#3B82F6" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-2">Agent-native</h3>
        <p class="text-sm text-[#8B949E] leading-relaxed">
          12 governance tools over MCP (HTTP/SSE). Any MCP-compatible agent calls ForgeOS directly — gate-check, delegation-validate, audit-query. Framework-agnostic. No SDK required.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Feature grid — 12 MCP tools -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">12 MCP TOOLS</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-3">
      What ForgeOS does
    </h2>
    <p class="text-[#9CA3AF] max-w-2xl mb-12">
      Twelve governance tools available over MCP (HTTP/SSE). Any MCP-compatible agent calls ForgeOS directly. Framework-agnostic.
    </p>

    <div class="space-y-10">
      {mcpTools.map((group) => (
        <div>
          <h3 class="text-xs font-semibold tracking-[0.12em] uppercase text-[#8B949E] mb-4">
            {group.category}
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {group.tools.map((tool) => (
              <div
                class="rounded-xl p-5 transition-all duration-200 group"
                style="background: #111111; border: 1px solid #1F1F1F;"
                onmouseover="this.style.borderColor='rgba(59,130,246,0.3)'; this.style.background='rgba(59,130,246,0.04)'"
                onmouseout="this.style.borderColor='#1F1F1F'; this.style.background='#111111'"
              >
                <div class="font-mono text-sm font-semibold text-[#3B82F6] mb-2">
                  {tool.name}
                </div>
                <p class="text-xs text-[#8B949E] leading-relaxed">
                  {tool.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- How it works -->
  <section id="how-it-works" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">HOW IT WORKS</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-12">
      Five steps. First gate in under 10 minutes.
    </h2>

    <div class="max-w-3xl space-y-0">
      {howItWorks.map((step, i) => (
        <div class="flex gap-6 pb-10 relative">
          <!-- Vertical line connector (not on last item) -->
          {i < howItWorks.length - 1 && (
            <div class="absolute left-[19px] top-10 bottom-0 w-px" style="background: #1F1F1F;"></div>
          )}
          <!-- Step number -->
          <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-xs font-semibold z-10"
               style="background: rgba(59,130,246,0.10); border: 1px solid rgba(59,130,246,0.3); color: #3B82F6;">
            {step.step}
          </div>
          <!-- Content -->
          <div class="pt-2">
            <h3 class="text-base font-semibold text-[#E6EDF3] mb-2">{step.headline}</h3>
            <p class="text-sm text-[#8B949E] leading-relaxed">{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <SectionDivider />

  <!-- Pricing preview -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">PRICING</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-3">
      Start in 14 days. Pay only if it works.
    </h2>
    <p class="text-[#9CA3AF] mb-10">Full Pro-tier access. No credit card required.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <!-- Pro — featured -->
      <div class="relative rounded-xl p-6" style="background: #111111; border: 1px solid #3B82F6; box-shadow: 0 0 0 1px rgba(59,130,246,0.15), 0 8px 32px rgba(59,130,246,0.08);">
        <!-- Most popular badge -->
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3.5 py-1 rounded-full text-xs font-semibold text-white"
             style="background: #3B82F6;">
          Most popular
        </div>
        <div class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold mb-4"
             style="background: rgba(59,130,246,0.12); color: #3B82F6;">
          Pro
        </div>
        <div class="flex items-baseline gap-1 mb-1">
          <span class="text-4xl font-bold text-[#E6EDF3]">$49</span>
          <span class="text-sm text-[#8B949E]">/month</span>
        </div>
        <p class="text-xs text-[#8B949E] mb-6">50,000 API calls/month</p>
        <a
          href="/forgeos/pricing#trial"
          class="block w-full text-center py-2.5 rounded-md font-medium text-white no-underline transition-all duration-150 mb-6"
          style="background: #3B82F6; font-size: 0.9375rem;"
          onmouseover="this.style.background='#2563EB'"
          onmouseout="this.style.background='#3B82F6'"
        >
          Start 14-day trial
        </a>
        <ul class="space-y-2.5 text-sm text-[#E6EDF3]">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Gate enforcement
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Ed25519-signed ledger
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            12 MCP governance tools
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            EU AI Act artifacts
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#8B949E" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-[#8B949E]">Team delegation rules</span>
          </li>
        </ul>
      </div>

      <!-- Team -->
      <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <div class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold mb-4"
             style="background: rgba(16,185,129,0.12); color: #10B981;">
          Team
        </div>
        <div class="flex items-baseline gap-1 mb-1">
          <span class="text-4xl font-bold text-[#E6EDF3]">$149</span>
          <span class="text-sm text-[#8B949E]">/month</span>
        </div>
        <p class="text-xs text-[#8B949E] mb-6">200,000 API calls/month</p>
        <a
          href="/forgeos/pricing#trial"
          class="block w-full text-center py-2.5 rounded-md font-medium no-underline transition-all duration-150 mb-6 text-[#E6EDF3]"
          style="border: 1px solid #1F1F1F; font-size: 0.9375rem;"
          onmouseover="this.style.borderColor='#8B949E'; this.style.background='rgba(255,255,255,0.04)'"
          onmouseout="this.style.borderColor='#1F1F1F'; this.style.background='transparent'"
        >
          Start 14-day trial
        </a>
        <ul class="space-y-2.5 text-sm text-[#E6EDF3]">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Everything in Pro
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="#10B981" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Team delegation rules
          </li>
          <li class="flex items-center gap-2">
