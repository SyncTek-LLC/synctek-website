---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SyncTek LLC',
  url: 'https://synctek.io',
  description:
    'SyncTek LLC is a Raleigh-based developer-infrastructure company building tools for the agent-first software development era. SimDrive is our flagship product.',
  sameAs: [
    'https://github.com/SyncTek-LLC',
    'https://simdrive.dev',
  ],
};
---

<BaseLayout
  title="SyncTek — Developer Infrastructure for the Agent-First Era"
  description="SyncTek LLC builds developer infrastructure for AI agents. Our flagship product is SimDrive — the MCP-native iOS simulator and real-device automation toolkit."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <!-- Hero background image -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none rounded-2xl" aria-hidden="true">
      <img
        src="/images/synctek-hero.png"
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center"
        style="opacity: 0.18;"
        loading="eager"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(180deg, rgba(10,10,10,0.0) 0%, rgba(10,10,10,0.55) 60%, rgba(10,10,10,0.95) 100%);"
      ></div>
    </div>
    <!-- Blue glow behind hero -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
        style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(59,130,246,0.12) 0%, transparent 70%);"
      ></div>
    </div>

    <div class="relative z-10">
      <!-- Overline -->
      <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-4">
        SyncTek LLC
      </p>

      <!-- Headline -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight max-w-3xl text-[#E6EDF3]"
        style="letter-spacing: -0.02em;"
      >
        Reproduce and validate iOS bugs<br />
        <span
          style="background: linear-gradient(135deg, #3B82F6, #1D4ED8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        >
          in 60 seconds with Claude.
        </span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-[#9CA3AF] max-w-2xl leading-relaxed">
        SyncTek builds developer infrastructure for AI agents. Our flagship product is <strong class="text-[#E6EDF3]">SimDrive</strong> —
        the MCP-native iOS simulator and real-device automation toolkit.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-wrap gap-4 items-center">
        <a
          href="https://simdrive.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 rounded-md font-medium text-white no-underline transition-all duration-150"
          style="background: #3B82F6; font-size: 1rem;"
          onmouseover="this.style.background='#2563EB'"
          onmouseout="this.style.background='#3B82F6'"
        >
          Visit simdrive.dev &rarr;
        </a>
        <a
          href="https://docs.simdrive.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium no-underline text-[#9CA3AF] hover:text-[#E6EDF3] transition-colors"
        >
          docs.simdrive.dev ↗
        </a>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- What is SimDrive -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">FLAGSHIP PRODUCT</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-4">
      What is SimDrive?
    </h2>
    <p class="text-[#9CA3AF] mb-4 max-w-3xl leading-relaxed">
      SimDrive is an MCP-native automation toolkit that lets Claude (and any MCP-aware agent) drive iOS Simulators
      and real iOS devices. Record once, replay deterministically, capture evidence — turn ambiguous bug reports
      into reproducible failures in under a minute.
    </p>
    <p class="text-[#9CA3AF] mb-8 max-w-3xl leading-relaxed">
      Built for engineers who want their AI assistant to actually <em>use the app</em>, not just read about it.
    </p>
    <a
      href="https://simdrive.dev"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center px-5 py-2.5 rounded-md font-medium text-white no-underline transition-all duration-150"
      style="background: #3B82F6;"
      onmouseover="this.style.background='#2563EB'"
      onmouseout="this.style.background='#3B82F6'"
    >
      See the full pitch at simdrive.dev &rarr;
    </a>
  </section>

  <SectionDivider />

  <!-- About SyncTek -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">THE COMPANY</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-4">
      About SyncTek
    </h2>
    <p class="text-[#9CA3AF] max-w-3xl leading-relaxed">
      SyncTek LLC is a Raleigh-based developer-infrastructure company building tools for the agent-first
      software development era. SimDrive is our flagship; more products are in the pipeline.
    </p>
  </section>

  <SectionDivider />

  <!-- Contact -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">GET IN TOUCH</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-6">
      Contact
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl">
      <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <h3 class="text-sm font-semibold text-[#E6EDF3] mb-2">SimDrive support</h3>
        <a href="mailto:support@simdrive.dev" class="text-sm text-[#3B82F6] no-underline hover:underline">support@simdrive.dev</a>
      </div>
      <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <h3 class="text-sm font-semibold text-[#E6EDF3] mb-2">Company</h3>
        <a href="mailto:hello@synctek.io" class="text-sm text-[#3B82F6] no-underline hover:underline">hello@synctek.io</a>
      </div>
      <div class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <h3 class="text-sm font-semibold text-[#E6EDF3] mb-2">GitHub</h3>
        <a href="https://github.com/SyncTek-LLC" target="_blank" rel="noopener noreferrer" class="text-sm text-[#3B82F6] no-underline hover:underline">github.com/SyncTek-LLC ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
