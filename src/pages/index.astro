---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import specterqa from '../data/products/specterqa';

// Get latest blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Calculate reading time
function getReadingTime(text: string): string {
  const wpm = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wpm);
  return `${minutes} min read`;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SyncTek LLC',
  url: 'https://synctek.io',
  description: 'AI-powered open-source developer tools',
  sameAs: [
    'https://github.com/SyncTek-LLC',
    'https://twitter.com/SyncTekLLC',
    'https://linkedin.com/company/synctek-llc',
  ],
};
---

<BaseLayout
  title="SyncTek"
  description="SyncTek builds AI-powered developer tools. CLI-first, open source, honest about what they do and what they cost."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight max-w-3xl">
      AI-powered developer tools that work on
      <span class="text-sync-green"> your terms</span>.
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-light-gray-500 dark:text-light-text max-w-2xl">
      CLI-first tools that solve real engineering problems. Open source where it counts. Honest about what they do and what they cost.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="/products/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-sync-green text-white font-semibold no-underline hover:bg-sync-green-hover transition-colors"
      >
        Explore Products
      </a>
      <a
        href="https://github.com/SyncTek-LLC"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-sync-green dark:hover:border-sync-green transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
        </svg>
        View on GitHub
      </a>
    </div>
  </section>

  <!-- Products -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-semibold mb-8">Products</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <ProductCard
        slug={specterqa.slug}
        name={specterqa.name}
        tagline={specterqa.tagline}
        type={specterqa.type}
        status={specterqa.status}
        license={specterqa.license}
        accentColor={specterqa.accentColor}
      />
    </div>
  </section>

  <!-- Latest blog posts -->
  {latestPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold">Latest from the blog</h2>
        <a
          href="/blog/"
          class="text-sm text-sync-green hover:underline no-underline font-medium"
        >
          View all posts &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            readingTime={getReadingTime(post.body || '')}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Open source callout -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="rounded-lg border border-light-border dark:border-border-gray p-8 sm:p-12">
      <h2 class="text-2xl font-semibold mb-4">Open source by default</h2>
      <p class="text-light-gray-500 dark:text-light-text max-w-2xl mb-6">
        The tools you run locally are MIT licensed. We open-source the CLI on your machine because the tool you depend on should not be a black box. Fork it, audit it, contribute to it.
      </p>
      <a
        href="https://github.com/SyncTek-LLC"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sync-green font-medium no-underline hover:underline"
      >
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
        </svg>
        View our repos on GitHub &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
