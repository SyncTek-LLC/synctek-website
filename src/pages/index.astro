---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { getCollection } from 'astro:content';
import specterqa from '../data/products/specterqa';

// Get latest blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Calculate reading time
function getReadingTime(text: string): string {
  const wpm = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wpm);
  return `${minutes} min read`;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SyncTek LLC',
  url: 'https://synctek.io',
  description: 'AI-powered developer tools that work on your terms',
  sameAs: [
    'https://github.com/SyncTek-LLC',
    'https://twitter.com/SyncTekLLC',
    'https://linkedin.com/company/synctek-llc',
  ],
};
---

<BaseLayout
  title="SyncTek"
  description="SyncTek builds AI-powered developer tools. Practical, transparent, and built for the way you actually work."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(176,176,176,0.12),transparent)]"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight max-w-3xl">
        AI-powered developer tools that work on
        <span class="bg-gradient-to-r from-[#808080] via-[#E0E0E0] to-[#A0A0A0] bg-clip-text text-transparent"> your terms</span>.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-light-gray-500 dark:text-light-text max-w-2xl">
        Tools that solve real engineering problems. Open source where it counts. Honest about what they do and what they cost.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/products/specterqa/#quickstart"
          class="inline-flex items-center px-6 py-3 rounded-lg bg-gradient-to-r from-[#909090] via-[#D0D0D0] to-[#909090] text-obsidian font-semibold no-underline shadow-[0_0_20px_rgba(176,176,176,0.25)] hover:shadow-[0_0_30px_rgba(176,176,176,0.4)] hover:scale-[1.02] transition-all duration-200"
        >
          Get Started
        </a>
        <a
          href="https://github.com/SyncTek-LLC"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver hover:bg-border-gray/30 transition-all duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Terminal preview -->
      <div class="mt-16 max-w-2xl">
        <div class="rounded-lg border border-border-gray dark:border-border-gray bg-[#0F0F0F] overflow-hidden shadow-[0_0_40px_rgba(176,176,176,0.06)]">
          <!-- Terminal chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-border-gray">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
            <span class="ml-2 text-xs text-muted font-mono">terminal</span>
          </div>
          <!-- Terminal content -->
          <div class="p-4 font-mono text-sm leading-relaxed">
            <div class="text-muted">$ <span class="text-terminal-white">pip install specterqa</span></div>
            <div class="text-[#3FB950] mt-1">Successfully installed specterqa-0.3.0</div>
            <div class="text-muted mt-3">$ <span class="text-terminal-white">specterqa run -p demo</span></div>
            <div class="text-accent-silver mt-1">Running persona "New User" on demo app...</div>
            <div class="text-accent-silver">Step 1/3: Navigate to login page <span class="text-[#3FB950]">PASS</span></div>
            <div class="text-accent-silver">Step 2/3: Complete login form <span class="text-[#3FB950]">PASS</span></div>
            <div class="text-accent-silver">Step 3/3: Verify dashboard loads <span class="text-[#3FB950]">PASS</span></div>
            <div class="text-[#3FB950] mt-2 font-semibold">3/3 steps passed — $0.42 spent</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Products -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-semibold tracking-tight mb-8">Products</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <ProductCard
        slug={specterqa.slug}
        name={specterqa.name}
        tagline={specterqa.tagline}
        type={specterqa.type}
        status={specterqa.status}
        license={specterqa.license}
        accentColor={specterqa.accentColor}
      />
      <!-- Coming soon placeholder -->
      <div class="rounded-lg border border-dashed border-border-gray dark:border-border-gray p-6 flex flex-col items-center justify-center text-center">
        <p class="text-muted text-sm font-medium">More tools in development</p>
        <p class="text-muted/60 text-xs mt-1">Stay tuned for announcements</p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Latest blog posts -->
  {latestPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold tracking-tight">Latest from the blog</h2>
        <a
          href="/blog/"
          class="text-sm text-accent-silver hover:text-accent-silver-hover hover:underline no-underline font-medium"
        >
          View all posts &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            readingTime={getReadingTime(post.body || '')}
          />
        ))}
      </div>
    </section>
  )}

  <SectionDivider />

  <!-- Open source callout -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="rounded-lg border border-light-border dark:border-border-gray p-8 sm:p-12">
      <h2 class="text-2xl font-semibold tracking-tight mb-4">Open where it counts</h2>
      <p class="text-light-gray-500 dark:text-light-text max-w-2xl mb-6">
        The tools you run locally are MIT licensed. We open-source the CLI on your machine because the tool you depend on should not be a black box. Fork it, audit it, contribute to it.
      </p>
      <a
        href="https://github.com/SyncTek-LLC"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-accent-silver font-medium no-underline hover:text-accent-silver-hover hover:underline"
      >
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
        </svg>
        View our repos on GitHub &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
