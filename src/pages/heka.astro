---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Heka',
  description:
    'Heka is the substrate for agentic engineering: persistent cross-session memory, governance gates with real separation of duties, and a multi-agent team, installed into any repo with one command.',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/PreOrder',
  },
};
---

<BaseLayout
  title="Heka: the substrate for agentic engineering"
  description="Heka gives your AI coding agent persistent cross-session memory, governance gates with real separation of duties, and a multi-agent team, installed into any repo with one command."
  jsonLd={jsonLd}
>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <!-- Ambient glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
        style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(59,130,246,0.10) 0%, transparent 70%);"
      ></div>
    </div>

    <div class="relative z-10 max-w-3xl">
      <!-- Eyebrow -->
      <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-4">
        Early access
      </p>

      <!-- Headline -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] text-[#E6EDF3]"
        style="letter-spacing: -0.02em;"
      >
        Your AI coding agent has amnesia.
        <span
          class="block mt-2"
          style="background: linear-gradient(135deg, #3B82F6, #1D4ED8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        >
          Heka gives it a memory, and a team.
        </span>
      </h1>

      <!-- Subhead -->
      <p class="mt-6 text-lg sm:text-xl text-[#9CA3AF] leading-relaxed">
        Heka is the substrate for agentic engineering: persistent cross-session memory, governance
        gates with real separation of duties, and a multi-agent team, installed into any repo with
        one command.
      </p>

      <!-- Email form: hero -->
      <div class="mt-10">
        <form
          id="hero-waitlist-form"
          class="flex flex-col sm:flex-row gap-3 max-w-lg"
          novalidate
          aria-label="Join the Heka waitlist"
        >
          <!-- Honeypot (hidden from humans, catches bots) -->
          <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            class="absolute -left-[9999px] opacity-0 pointer-events-none"
          />
          <label for="hero-email" class="sr-only">Email address</label>
          <input
            id="hero-email"
            name="email"
            type="email"
            required
            placeholder="you@company.com"
            autocomplete="email"
            class="flex-1 px-4 py-3 rounded-md text-sm font-medium bg-[#111111] border border-[#1F1F1F] text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#3B82F6] transition-colors"
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-md font-medium text-white text-sm whitespace-nowrap transition-all duration-150 heka-submit-btn"
            style="background: #3B82F6;"
            onmouseover="this.style.background='#2563EB'"
            onmouseout="this.style.background='#3B82F6'"
          >
            Join the waitlist
          </button>
        </form>
        <!-- Inline feedback -->
        <div id="hero-waitlist-status" class="mt-3 text-sm hidden" aria-live="polite"></div>
        <p class="mt-3 text-xs text-[#8B949E]">
          No spam. Early access and product updates, nothing else.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================================
       THE PROBLEM
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">The problem</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
      Your agent forgets everything.
    </h2>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6" role="list">
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#9CA3AF] leading-relaxed">
          It forgets context every session, and re-introduces bugs you already fixed.
        </p>
      </li>
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#9CA3AF] leading-relaxed">
          There is no governance: merged does not mean working, with no review and no audit trail.
        </p>
      </li>
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#9CA3AF] leading-relaxed">
          You are the orchestration layer, and that does not scale across repos.
        </p>
      </li>
    </ul>
  </section>

  <SectionDivider />

  <!-- ============================================================
       HOW IT WORKS: THREE PILLARS
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">How it works</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
      Three pillars.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Pillar 1 -->
      <div>
        <div
          class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-[#3B82F6] font-mono font-bold text-sm"
          style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);"
          aria-hidden="true"
        >
          01
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-3">Memory that compounds</h3>
        <p class="text-[#9CA3AF] leading-relaxed text-sm">
          Every bug fixed, convention learned, and architectural scar becomes permanent
          cross-session knowledge. Your agents stop repeating the mistakes you already paid for.
        </p>
      </div>
      <!-- Pillar 2 -->
      <div>
        <div
          class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-[#3B82F6] font-mono font-bold text-sm"
          style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);"
          aria-hidden="true"
        >
          02
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-3">Governance you can trust</h3>
        <p class="text-[#9CA3AF] leading-relaxed text-sm">
          Multi-agent roles with real separation of duties, the architect and QA reviewers cannot
          approve their own work. Every material action is logged, and you choose the gates.
          Autonomy without the black box.
        </p>
      </div>
      <!-- Pillar 3 -->
      <div>
        <div
          class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-[#3B82F6] font-mono font-bold text-sm"
          style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);"
          aria-hidden="true"
        >
          03
        </div>
        <h3 class="text-lg font-semibold text-[#E6EDF3] mb-3">Portable in one command</h3>
        <p class="text-[#9CA3AF] leading-relaxed text-sm">
          Install Heka into any repo. It bootstraps the codebase, learns its critical paths,
          and adapts to your conventions, not the other way around.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================================
       THE FULL TOOLSET
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">The full toolset</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-4">
      Eight capabilities. One substrate.
    </h2>
    <p class="text-[#9CA3AF] leading-relaxed mb-10 max-w-2xl">
      Heka is not a prompt. It is the working substrate underneath your agents.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Card 1 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">A coordinated agent team</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Multiple agents work in parallel over a shared bridge, each in its own isolated workspace. Not one session doing everything.
        </p>
      </div>
      <!-- Card 2 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">Memory that won't go stale</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Institutional knowledge with freshness tracking, so agents re-verify aging facts instead of trusting them blindly.
        </p>
      </div>
      <!-- Card 3 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">Separation-of-duties review</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Independent architect and QA reviewers that cannot approve their own work, with every material action logged to a signed evidence trail.
        </p>
      </div>
      <!-- Card 4 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">A codebase that remembers how it broke</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Past failures and decisions resurface automatically when an agent touches a risky area.
        </p>
      </div>
      <!-- Card 5 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">Real device and simulator testing</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Auto-allocated simulators, record-once visual-regression replay that runs free in CI, and rebuild checks that catch stale-binary false passes.
        </p>
      </div>
      <!-- Card 6 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">One-command, non-destructive install</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Drops into any repo, recons it, learns its critical paths, and never overwrites your files.
        </p>
      </div>
      <!-- Card 7 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">Knowledge capture on day one</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          A structured senior-engineer interview captures domain knowledge before the expert rotates off.
        </p>
      </div>
      <!-- Card 8 -->
      <div class="rounded-xl p-6 bg-[#111111] border border-[#1F1F1F]">
        <h3 class="text-[#E6EDF3] font-semibold text-sm mb-2">A harness that improves itself</h3>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Every escaped bug becomes a new permanent guardrail, and improvements propagate across your projects.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================================
       PROOF
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">Proof</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
      This is not a demo.
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- 4-stat cluster -->
      <div
        class="rounded-xl p-8 lg:col-span-3"
        style="background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.25);"
      >
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
          <div class="text-center">
            <p
              class="text-3xl sm:text-4xl font-bold leading-tight mb-1"
              style="background: linear-gradient(135deg, #3B82F6, #60A5FA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              +208%
            </p>
            <p class="text-xs text-[#8B949E] leading-snug">merged PRs per week (40 vs a 13/week baseline)</p>
          </div>
          <div class="text-center">
            <p
              class="text-3xl sm:text-4xl font-bold leading-tight mb-1"
              style="background: linear-gradient(135deg, #3B82F6, #60A5FA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              0
            </p>
            <p class="text-xs text-[#8B949E] leading-snug">reverts</p>
          </div>
          <div class="text-center">
            <p
              class="text-3xl sm:text-4xl font-bold leading-tight mb-1"
              style="background: linear-gradient(135deg, #3B82F6, #60A5FA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              +55%
            </p>
            <p class="text-xs text-[#8B949E] leading-snug">commit volume</p>
          </div>
          <div class="text-center">
            <p
              class="text-3xl sm:text-4xl font-bold leading-tight mb-1"
              style="background: linear-gradient(135deg, #3B82F6, #60A5FA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              0.86
            </p>
            <p class="text-xs text-[#8B949E] leading-snug">test-to-source ratio</p>
          </div>
        </div>
        <p class="text-xs text-[#8B949E] leading-relaxed text-center">
          One week of real git telemetry from a large production iOS app, run on Heka. Reproducible from repo history, not self-reported.
        </p>
      </div>

      <!-- Case study card -->
      <div
        class="rounded-xl p-8 lg:col-span-2"
        style="background: #111111; border: 1px solid #1F1F1F;"
      >
        <p class="text-xs font-semibold tracking-[0.10em] uppercase text-[#8B949E] mb-2">
          We built a real product this way
        </p>
        <h3 class="text-xl font-semibold text-[#E6EDF3] mb-4">RefSource</h3>
        <p class="text-[#9CA3AF] leading-relaxed text-sm">
          RefSource is a two-sided referral marketplace, an iOS app plus an eight-service backend,
          built end to end by a fleet of Claude agents running on Heka. Three coordinator sessions
          talked live over a peer-bridge while dozens of sub-agents ran parallel lanes, each
          isolated in its own git worktree. Every lane was test-first, independently reviewed
          under separation of duties, and gated before merge, with production deploys hard-locked
          behind human approval. The agents verified assumptions against live code and the real
          database before writing, catching product gaps a spec review would miss.
        </p>
      </div>

      <!-- Shipped card -->
      <div
        class="rounded-xl p-8"
        style="background: #111111; border: 1px solid #1F1F1F;"
      >
        <p class="text-xs font-semibold tracking-[0.10em] uppercase text-[#8B949E] mb-2">
          Shipped, public, live
        </p>
        <p class="text-[#9CA3AF] leading-relaxed text-sm">
          SimDrive, our iOS verification tool, is live on PyPI today
          (<code class="text-[#D4D4D4] font-mono text-xs">pip install simdrive</code>).
          Proof the company ships.
        </p>
      </div>

      <!-- Link row -->
      <div
        class="rounded-xl p-8 lg:col-span-2"
        style="background: #111111; border: 1px solid #1F1F1F;"
      >
        <p class="text-xs font-semibold tracking-[0.10em] uppercase text-[#8B949E] mb-4">
          Read the thinking:
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/blog/2026-06-18-epistemic-engineering/"
            class="inline-flex items-center gap-1 text-sm text-[#3B82F6] no-underline hover:underline font-medium"
          >
            Epistemic Engineering &rarr;
          </a>
          <a
            href="/blog/2026-06-18-autonomous-multi-agent-feature-delivery/"
            class="inline-flex items-center gap-1 text-sm text-[#3B82F6] no-underline hover:underline font-medium"
          >
            Autonomous Multi-Agent Feature Delivery &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================================
       WHO IT'S FOR
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">Who it's for</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
      Built for builders who already live in their agent.
    </h2>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6" role="list">
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#E6EDF3] font-medium mb-2">The over-extended senior builder</p>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Running two to four repos who already lives in an AI coding agent.
        </p>
      </li>
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#E6EDF3] font-medium mb-2">The small-team lead</p>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Who wants juniors and agents to ship without reviewing every line.
        </p>
      </li>
      <li class="rounded-xl p-6" style="background: #111111; border: 1px solid #1F1F1F;">
        <p class="text-[#E6EDF3] font-medium mb-2">The platform engineer</p>
        <p class="text-[#9CA3AF] text-sm leading-relaxed">
          Chartered to make AI coding safe, auditable, and repeatable for the org.
        </p>
      </li>
    </ul>
  </section>

  <SectionDivider />

  <!-- ============================================================
       FAQ
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <p class="text-xs font-semibold tracking-[0.12em] uppercase text-[#3B82F6] mb-3">FAQ</p>
    <h2 class="text-2xl sm:text-3xl font-semibold text-[#E6EDF3] tracking-tight mb-10">
      Common questions.
    </h2>
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 max-w-4xl">
      <div>
        <dt class="text-[#E6EDF3] font-medium mb-2">Does Heka replace Claude Code or Cursor?</dt>
        <dd class="text-[#9CA3AF] text-sm leading-relaxed">
          No. Heka wraps the coding agent you already use, it does not compete with it.
        </dd>
      </div>
      <div>
        <dt class="text-[#E6EDF3] font-medium mb-2">Does it work with my stack?</dt>
        <dd class="text-[#9CA3AF] text-sm leading-relaxed">
          Heka installs into any repo with one command and bootstraps your conventions. It is
          language and framework agnostic.
        </dd>
      </div>
      <div>
        <dt class="text-[#E6EDF3] font-medium mb-2">Is it autonomous like Devin?</dt>
        <dd class="text-[#9CA3AF] text-sm leading-relaxed">
          No. Heka is governed and human-in-the-loop, with a full audit trail. You stay in
          control; the gates are yours.
        </dd>
      </div>
      <div>
        <dt class="text-[#E6EDF3] font-medium mb-2">When can I get it?</dt>
        <dd class="text-[#9CA3AF] text-sm leading-relaxed">
          Join the waitlist for early access and to help shape it.
        </dd>
      </div>
    </dl>
  </section>

  <SectionDivider />

  <!-- ============================================================
       FINAL CTA
  ============================================================ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
    <div
      class="rounded-2xl px-8 py-16 sm:px-16 text-center relative overflow-hidden"
      style="background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.20);"
    >
      <!-- Ambient glow inside card -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-48"
          style="background: radial-gradient(ellipse 50% 60% at 50% 0%, rgba(59,130,246,0.10) 0%, transparent 70%);"
        ></div>
      </div>

      <div class="relative z-10 max-w-xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#E6EDF3] tracking-tight mb-3" style="letter-spacing: -0.02em;">
          Get early access to Heka.
        </h2>
        <p class="text-[#9CA3AF] mb-8 leading-relaxed">
          Join the waitlist and we will reach out when it is ready.
        </p>

        <form
          id="footer-waitlist-form"
          class="flex flex-col sm:flex-row gap-3 justify-center"
          novalidate
          aria-label="Join the Heka waitlist"
        >
          <!-- Honeypot -->
          <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            class="absolute -left-[9999px] opacity-0 pointer-events-none"
          />
          <label for="footer-email" class="sr-only">Email address</label>
          <input
            id="footer-email"
            name="email"
            type="email"
            required
            placeholder="you@company.com"
            autocomplete="email"
            class="flex-1 max-w-sm px-4 py-3 rounded-md text-sm font-medium bg-[#111111] border border-[#1F1F1F] text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#3B82F6] transition-colors"
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-md font-medium text-white text-sm whitespace-nowrap transition-all duration-150"
            style="background: #3B82F6;"
            onmouseover="this.style.background='#2563EB'"
            onmouseout="this.style.background='#3B82F6'"
          >
            Join the waitlist
          </button>
        </form>
        <!-- Inline feedback -->
        <div id="footer-waitlist-status" class="mt-3 text-sm hidden" aria-live="polite"></div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Waitlist form handler - progressive enhancement (JS fetch)
  // Honors prefers-reduced-motion for any animations
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface WaitlistResponse {
    ok: boolean;
    error?: string;
  }

  async function submitWaitlist(
    form: HTMLFormElement,
    statusEl: HTMLElement,
    source: string
  ): Promise<void> {
    const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const honeypotInput = form.querySelector<HTMLInputElement>('input[name="company"]');

    if (!emailInput || !submitBtn) return;

    const email = emailInput.value.trim();
    const honeypot = honeypotInput?.value ?? '';

    // Client-side email validation
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showStatus(statusEl, 'Please enter a valid email address.', 'error');
      emailInput.focus();
      return;
    }

    // Disable form during submission
    submitBtn.disabled = true;
    submitBtn.textContent = 'Joining...';

    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source, company: honeypot }),
      });

      const data: WaitlistResponse = await res.json().catch(() => ({ ok: false }));

      if (res.ok && data.ok) {
        showStatus(statusEl, "You're on the list. We'll be in touch.", 'success');
        emailInput.value = '';
        submitBtn.textContent = 'Joined!';
        submitBtn.disabled = true;
      } else if (res.status === 400) {
        showStatus(statusEl, 'Please enter a valid email address.', 'error');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Join the waitlist';
      } else if (res.status === 503) {
        showStatus(
          statusEl,
          'Sign-ups are temporarily unavailable. Try again shortly.',
          'error'
        );
        submitBtn.disabled = false;
        submitBtn.textContent = 'Join the waitlist';
      } else {
        showStatus(
          statusEl,
          'Something went wrong. Please try again or email us at support@simdrive.dev.',
          'error'
        );
        submitBtn.disabled = false;
        submitBtn.textContent = 'Join the waitlist';
      }
    } catch {
      showStatus(
        statusEl,
        'Connection error. Please check your network and try again.',
        'error'
      );
      submitBtn.disabled = false;
      submitBtn.textContent = 'Join the waitlist';
    }
  }

  function showStatus(el: HTMLElement, message: string, type: 'success' | 'error'): void {
    el.textContent = message;
    el.className = [
      'mt-3 text-sm',
      type === 'success' ? 'text-[#3FB950]' : 'text-[#F85149]',
    ].join(' ');
    el.removeAttribute('hidden');
    el.classList.remove('hidden');

    // Animate in unless reduced motion
    if (!prefersReducedMotion) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(-4px)';
      el.style.transition = 'opacity 200ms ease, transform 200ms ease';
      requestAnimationFrame(() => {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    }
  }

  function wireForm(formId: string, statusId: string, source: string): void {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const statusEl = document.getElementById(statusId) as HTMLElement | null;
    if (!form || !statusEl) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submitWaitlist(form, statusEl, source);
    });
  }

  wireForm('hero-waitlist-form', 'hero-waitlist-status', 'heka-hero');
  wireForm('footer-waitlist-form', 'footer-waitlist-status', 'heka-footer');

  // Re-wire after Astro view transitions
  document.addEventListener('astro:after-swap', () => {
    wireForm('hero-waitlist-form', 'hero-waitlist-status', 'heka-hero');
    wireForm('footer-waitlist-form', 'footer-waitlist-status', 'heka-footer');
  });
</script>
