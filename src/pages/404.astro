---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist or has been moved."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-bold text-accent-silver mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold mb-4">Page not found</h1>
    <p class="text-light-gray-500 dark:text-muted mb-8 max-w-md mx-auto">
      The page you are looking for does not exist or has been moved. Check the URL or navigate back home.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-accent-silver text-obsidian font-semibold no-underline hover:bg-accent-silver-hover transition-colors"
      >
        Go home
      </a>
      <a
        href="/products/"
        class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
      >
        View products
      </a>
      <a
        href="/blog/"
        class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
      >
        Read the blog
      </a>
    </div>
  </section>
</BaseLayout>
