---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist or has been moved."
>
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,rgba(176,176,176,0.08),transparent)]"></div>
    </div>
    <div class="relative z-10">
      <p class="text-7xl sm:text-8xl font-bold bg-gradient-to-b from-[#808080] via-[#D0D0D0] to-[#505050] bg-clip-text text-transparent mb-4 select-none">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Page not found</h1>
      <p class="text-light-gray-500 dark:text-muted mb-8 max-w-md mx-auto">
        The page you are looking for does not exist or has been moved. Check the URL or navigate back home.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 rounded-lg bg-accent-silver text-obsidian font-semibold no-underline hover:bg-accent-silver-hover transition-colors"
        >
          Go home
        </a>
        <a
          href="/products/"
          class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
        >
          View products
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center px-6 py-3 rounded-lg border border-light-border dark:border-border-gray font-semibold no-underline hover:border-accent-silver dark:hover:border-accent-silver transition-colors"
        >
          Read the blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
