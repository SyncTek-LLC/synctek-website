---
interface Props {
  text: string;
  variant?: 'green' | 'yellow' | 'gray' | 'blue' | 'purple' | 'red' | 'silver';
  size?: 'sm' | 'md';
}

const { text, variant = 'gray', size = 'sm' } = Astro.props;

const variantClasses: Record<string, string> = {
  green: 'bg-[#3FB950]/15 text-[#3FB950] border-[#3FB950]/30',
  silver: 'bg-accent-silver/15 text-accent-silver border-accent-silver/30',
  yellow: 'bg-warning-amber/15 text-warning-amber border-warning-amber/30',
  gray: 'bg-muted/15 text-muted border-muted/30',
  blue: 'bg-[#58A6FF]/15 text-[#58A6FF] border-[#58A6FF]/30',
  purple: 'bg-accent-purple/15 text-accent-purple border-accent-purple/30',
  red: 'bg-error-red/15 text-error-red border-error-red/30',
};

const sizeClasses: Record<string, string> = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-sm px-3 py-1',
};
---

<span class:list={[
  'inline-flex items-center rounded-full border font-medium',
  variantClasses[variant],
  sizeClasses[size],
]}>
  {text}
</span>
