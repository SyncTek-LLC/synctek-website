---
// Theme toggle component - dark/light mode
// Uses data attributes + querySelectorAll for multi-instance support
---

<button
  data-theme-toggle
  type="button"
  aria-label="Toggle dark mode"
  class="relative p-2 rounded-lg transition-colors hover:bg-light-surface dark:hover:bg-border-gray"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    data-sun-icon
    class="w-5 h-5 hidden"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg
    data-moon-icon
    class="w-5 h-5 hidden"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script>
  function initThemeToggles() {
    const toggles = document.querySelectorAll('[data-theme-toggle]');
    const sunIcons = document.querySelectorAll('[data-sun-icon]');
    const moonIcons = document.querySelectorAll('[data-moon-icon]');

    function getTheme(): 'dark' | 'light' {
      const stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') return stored;
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    function applyTheme(theme: 'dark' | 'light') {
      const html = document.documentElement;
      if (theme === 'dark') {
        html.classList.add('dark');
        sunIcons.forEach((icon) => icon.classList.remove('hidden'));
        moonIcons.forEach((icon) => icon.classList.add('hidden'));
      } else {
        html.classList.remove('dark');
        sunIcons.forEach((icon) => icon.classList.add('hidden'));
        moonIcons.forEach((icon) => icon.classList.remove('hidden'));
      }
    }

    // Apply current theme to all icons
    applyTheme(getTheme());

    // Attach click handler to each toggle instance
    toggles.forEach((toggle) => {
      // Remove existing listeners by cloning (prevents duplicates on re-init)
      const fresh = toggle.cloneNode(true) as HTMLElement;
      toggle.parentNode?.replaceChild(fresh, toggle);

      fresh.addEventListener('click', () => {
        const current = getTheme();
        const next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme(next);
      });
    });
  }

  // Run on initial load and on Astro page transitions
  initThemeToggles();
  document.addEventListener('astro:after-swap', initThemeToggles);
</script>
