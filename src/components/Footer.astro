---
const footerLinks = [
  { label: 'Products', href: '/products/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Open Source', href: '/open-source/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-light-border dark:border-border-gray mt-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <a href="/" class="flex items-center no-underline">
          <img src="/images/synctek-logo.png" alt="SyncTek" class="h-8 w-auto" />
        </a>
        <p class="text-sm text-light-gray-500 dark:text-muted max-w-xs">
          AI-powered developer tools. Honest software that works on your terms.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-col gap-2" aria-label="Footer navigation">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white no-underline transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Social links -->
      <div class="flex flex-row md:flex-col gap-4 md:gap-3">
        <a
          href="https://github.com/SyncTek-LLC"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white no-underline transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
          </svg>
          <span class="hidden md:inline">GitHub</span>
        </a>
        <a
          href="https://twitter.com/SyncTekLLC"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white no-underline transition-colors"
          aria-label="Twitter / X"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          <span class="hidden md:inline">Twitter / X</span>
        </a>
        <a
          href="https://linkedin.com/company/synctek-llc"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white no-underline transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          <span class="hidden md:inline">LinkedIn</span>
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-6 border-t border-light-border dark:border-border-gray flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-light-gray-500 dark:text-muted">
        &copy; {currentYear} SyncTek LLC. All rights reserved.
      </p>
      <p class="text-sm text-light-gray-500 dark:text-muted">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-light-text-primary dark:hover:text-terminal-white no-underline">Astro</a>
      </p>
    </div>
  </div>
</footer>
