---
import Badge from './Badge.astro';

interface Props {
  slug: string;
  name: string;
  tagline: string;
  type: string;
  status: string;
  license: string;
  accentColor?: string;
  href?: string;
  ctaType?: 'login' | 'install' | 'coming-soon';
  loginUrl?: string;
  installCommand?: string;
  icon?: string;
}

const { slug, name, tagline, type, status, license, accentColor = '#B0B0B0', href, ctaType, loginUrl, installCommand, icon } = Astro.props;
const cardHref = href ?? `/products/${slug}/`;

const statusVariant = {
  launched: 'silver' as const,
  beta: 'yellow' as const,
  'coming-soon': 'gray' as const,
};
---

<a
  href={cardHref}
  class="group block rounded-lg border border-light-border dark:border-border-gray p-6 no-underline card-hover hover:border-accent-silver dark:hover:border-accent-silver"
  style={`border-left: 3px solid ${accentColor}`}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2.5">
      {icon && (
        <img
          src={icon}
          alt={name}
          width="40"
          height="40"
          loading="lazy"
          style="width: 40px; height: 40px; border-radius: 8px; flex-shrink: 0;"
        />
      )}
      <h3 class="text-lg font-semibold text-light-text-primary dark:text-terminal-white group-hover:text-accent-silver-hover transition-colors">
        {name}
      </h3>
    </div>
    <Badge text={status === 'coming-soon' ? 'Coming Soon' : status.charAt(0).toUpperCase() + status.slice(1)} variant={statusVariant[status as keyof typeof statusVariant] || 'gray'} />
  </div>
  <p class="text-sm text-light-gray-500 dark:text-muted mb-4">{tagline}</p>
  <div class="flex items-center gap-2 mb-4">
    <Badge text={type} variant="blue" />
    <Badge text={license} variant="purple" />
  </div>
  {ctaType === 'login' && (
    <div class="mt-2 pt-3 border-t border-light-border dark:border-border-gray">
      <span class="text-sm font-medium" style={`color: ${accentColor}`}>Get Started &rarr;</span>
    </div>
  )}
  {ctaType === 'install' && installCommand && (
    <div class="mt-2 pt-3 border-t border-light-border dark:border-border-gray">
      <code class="text-xs font-mono text-light-gray-500 dark:text-muted">{installCommand}</code>
    </div>
  )}
  {ctaType === 'coming-soon' && (
    <div class="mt-2 pt-3 border-t border-light-border dark:border-border-gray">
      <span class="text-sm text-light-gray-500 dark:text-muted">Coming soon</span>
    </div>
  )}
</a>
