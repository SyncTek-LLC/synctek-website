---
import Badge from './Badge.astro';

interface Props {
  name: string;
  org: string;
  description: string;
  language: string;
  stars: number;
  license: string;
  topics: string[];
  featured?: boolean;
}

const { name, org, description, language, stars, license, topics, featured = false } = Astro.props;

const languageColors: Record<string, string> = {
  Python: '#3572A5',
  JavaScript: '#F1E05A',
  TypeScript: '#3178C6',
  Rust: '#DEA584',
  Go: '#00ADD8',
};
---

<a
  href={`https://github.com/${org}/${name}`}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'group block rounded-lg border p-6 no-underline card-hover hover:border-accent-silver dark:hover:border-accent-silver',
    featured
      ? 'border-accent-silver/50 dark:border-accent-silver/50'
      : 'border-light-border dark:border-border-gray',
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-light-gray-500 dark:text-muted" viewBox="0 0 16 16" fill="currentColor">
        <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
      </svg>
      <h3 class="text-base font-semibold text-light-text-primary dark:text-terminal-white group-hover:text-accent-silver-hover transition-colors">
        {org}/{name}
      </h3>
    </div>
    {featured && <Badge text="Featured" variant="green" />}
  </div>

  <p class="text-sm text-light-gray-500 dark:text-muted mb-4">{description}</p>

  <div class="flex items-center gap-4 text-xs text-light-gray-500 dark:text-muted">
    <span class="flex items-center gap-1">
      <span class="w-3 h-3 rounded-full" style={`background-color: ${languageColors[language] || '#8B949E'}`}></span>
      {language}
    </span>
    {stars > 0 && (
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
        </svg>
        {stars}
      </span>
    )}
    <span>{license}</span>
  </div>

  {topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {topics.map((topic) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-accent-silver/10 text-accent-silver">
          {topic}
        </span>
      ))}
    </div>
  )}
</a>
