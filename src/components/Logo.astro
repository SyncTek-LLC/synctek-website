---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<div class:list={['logo-container', className]} style={`height: ${height}px;`}>
  <img
    src="/images/synctek-icon.png"
    alt=""
    class="logo-icon"
    height={height}
    width={height}
  />
  <span class="logo-text">SYNCTEK</span>
</div>

<style>
  .logo-container {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo-icon {
    object-fit: contain;
    /* Dark mode: invert the black icon to white */
    filter: invert(0);
  }

  :global(.dark) .logo-icon {
    filter: invert(1);
  }

  .logo-text {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1.2em;
    letter-spacing: 0.1em;
    color: #171717;
    line-height: 1;
  }

  :global(.dark) .logo-text {
    color: #E5E5E5;
  }
</style>
