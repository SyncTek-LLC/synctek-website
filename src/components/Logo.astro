---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<svg
  class:list={['logo-svg', className]}
  height={height}
  viewBox="0 0 200 40"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SyncTek"
>
  <style>
    .st-txt { fill: #E5E5E5; }
    :root:not(.dark) .st-txt { fill: #171717; }
  </style>
  <text
    class="st-txt"
    x="0"
    y="30"
    font-family="Inter, system-ui, -apple-system, sans-serif"
    font-size="36"
    font-weight="700"
    letter-spacing="-0.03em"
    text-rendering="geometricPrecision"
    dominant-baseline="auto"
  >SyncTek</text>
</svg>
