---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<svg
  class:list={['logo-svg', className]}
  height={height}
  viewBox="0 0 370 40"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SyncTek"
>
  <defs>
    <clipPath id="globe-clip">
      <circle cx="20" cy="20" r="17"/>
    </clipPath>
  </defs>

  <style>
    .st-icon { stroke: #E5E5E5; fill: none; }
    .st-land { fill: #E5E5E5; stroke: none; }
    .st-grid { stroke: #E5E5E5; opacity: 0.25; }
    .st-txt { fill: #E5E5E5; }

    :root:not(.dark) .st-icon { stroke: #171717; }
    :root:not(.dark) .st-land { fill: #171717; }
    :root:not(.dark) .st-grid { stroke: #171717; }
    :root:not(.dark) .st-txt { fill: #171717; }
  </style>

  <!-- Globe icon -->
  <g>
    <!-- Circle outline -->
    <circle class="st-icon" cx="20" cy="20" r="17" stroke-width="1.5"/>

    <!-- Grid lines (clipped, subtle) -->
    <g clip-path="url(#globe-clip)">
      <line class="st-grid" x1="3" y1="13" x2="37" y2="13" stroke-width="0.6"/>
      <line class="st-grid" x1="3" y1="27" x2="37" y2="27" stroke-width="0.6"/>
      <ellipse class="st-grid" cx="20" cy="20" rx="7" ry="17" stroke-width="0.6" fill="none"/>
    </g>

    <!-- Abstract continent shapes (clipped to globe) -->
    <g clip-path="url(#globe-clip)">
      <!-- Top-left landmass — angular, suggesting North America/Europe -->
      <polygon class="st-land" points="8,7 17,5 19,12 14,16 6,14"/>
      <!-- Center-right landmass — angular, suggesting Asia -->
      <polygon class="st-land" points="23,11 35,9 37,18 30,22 24,19"/>
      <!-- Bottom landmass — angular, suggesting Africa/South America -->
      <polygon class="st-land" points="12,24 22,22 26,28 20,34 10,32"/>
    </g>

    <!-- Fragments that "cut through" the globe border (NOT clipped) -->
    <polygon class="st-land" points="35,8 39,6 40,10 37,11"/>
    <polygon class="st-land" points="7,31 3,34 5,37 9,34"/>
    <polygon class="st-land" points="18,2 22,0 23,3 19,4"/>
  </g>

  <!-- Wordmark -->
  <text
    class="st-txt"
    x="48"
    y="32"
    font-family="'Orbitron', sans-serif"
    font-size="36"
    font-weight="700"
    letter-spacing="2"
    text-rendering="geometricPrecision"
    dominant-baseline="auto"
  >SYNCTEK</text>
</svg>
