---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<svg
  class:list={['logo-svg', className]}
  height={height}
  viewBox="0 0 280 72"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SyncTek"
>
  <defs>
    <!-- ====== DARK MODE GRADIENTS (chrome on dark bg) ====== -->

    <!-- Main S body: top-lit chrome -->
    <linearGradient id="st-s-main" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E0E0E0" />
      <stop offset="20%" stop-color="#C8C8C8" />
      <stop offset="55%" stop-color="#909090" />
      <stop offset="85%" stop-color="#6A6A6A" />
      <stop offset="100%" stop-color="#585858" />
    </linearGradient>

    <!-- Inner highlight: bright specular edge -->
    <linearGradient id="st-s-hi" x1="0.2" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.45" />
      <stop offset="40%" stop-color="#F0F0F0" stop-opacity="0.2" />
      <stop offset="100%" stop-color="#C0C0C0" stop-opacity="0" />
    </linearGradient>

    <!-- Text chrome -->
    <linearGradient id="st-text" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F0F0F0" />
      <stop offset="25%" stop-color="#DCDCDC" />
      <stop offset="75%" stop-color="#A0A0A0" />
      <stop offset="100%" stop-color="#808080" />
    </linearGradient>

    <!-- ====== LIGHT MODE GRADIENTS (darkened for white bg) ====== -->

    <linearGradient id="st-s-main-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#555555" />
      <stop offset="20%" stop-color="#484848" />
      <stop offset="55%" stop-color="#363636" />
      <stop offset="85%" stop-color="#2A2A2A" />
      <stop offset="100%" stop-color="#1E1E1E" />
    </linearGradient>

    <linearGradient id="st-s-hi-lt" x1="0.2" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#888888" stop-opacity="0.4" />
      <stop offset="40%" stop-color="#707070" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#555555" stop-opacity="0" />
    </linearGradient>

    <linearGradient id="st-text-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#333333" />
      <stop offset="25%" stop-color="#282828" />
      <stop offset="75%" stop-color="#1A1A1A" />
      <stop offset="100%" stop-color="#111111" />
    </linearGradient>
  </defs>

  <style>
    /* Dark mode (default) */
    .st-body { fill: url(#st-s-main); }
    .st-hi   { fill: url(#st-s-hi); }
    .st-txt  { fill: url(#st-text); }
    .st-px   { fill: #B0B0B0; }

    /* Light mode */
    :root:not(.dark) .st-body { fill: url(#st-s-main-lt); }
    :root:not(.dark) .st-hi   { fill: url(#st-s-hi-lt); }
    :root:not(.dark) .st-txt  { fill: url(#st-text-lt); }
    :root:not(.dark) .st-px   { fill: #505050; }
  </style>

  <!--
    S LOGOMARK — Geometric, bold, single-form S
    Design: One thick S path with rounded terminals, inspired by
    modern geometric type (Stripe, Spotify confidence level).
    The S is ~62px tall, centered vertically in the 72px viewBox.
  -->
  <g transform="translate(4, 4)">
    <!--
      MAIN S BODY — single closed path
      Constructed as an outlined S glyph: outer contour clockwise,
      inner contour counter-clockwise (cutout).

      Anatomy:
      - Top terminal: rounded cap flowing right
      - Upper bowl: curves left and down
      - Spine: diagonal connecting upper and lower bowls
      - Lower bowl: curves right and down
      - Bottom terminal: rounded cap flowing left

      Stroke weight: ~14px visual thickness
    -->
    <path class="st-body" d="
      M 48,3
      C 37,-1 22,-2 13,6
      C 3,14 2,27 13,34
      C 16,36 22,39 30,43
      C 39,47 43,52 40,57
      C 37,62 27,65 18,63
      C 13,62 9,59 7,56
      L 3,59
      C 7,64 14,68 24,69
      C 37,70 50,66 55,57
      C 61,47 55,38 44,32
      C 40,30 34,27 27,23
      C 19,19 16,13 20,8
      C 24,4 33,2 42,4
      C 47,5 51,7 53,10
      L 57,7
      C 54,4 51,2 48,3
      Z
    " />

    <!--
      INNER HIGHLIGHT — subtle specular edge along the upper-left
      contour of the S, giving a gentle chrome/metallic dimensionality
      without the muddiness of overlapping shapes.
    -->
    <path class="st-hi" d="
      M 46,4
      C 36,0 24,0 15,7
      C 6,14 5,25 14,32
      L 21,27
      C 15,23 15,15 21,9
      C 27,4 37,2.5 45,4.5
      Z
    " />

    <!--
      PIXEL DISSOLVE — data fragments breaking off the top-right
      terminal of the S. Suggests digital/sync. 4 squares,
      cascading in size and opacity from near to far.
    -->
    <rect class="st-px" x="57" y="0" width="4" height="4" rx="0.5" opacity="0.8" />
    <rect class="st-px" x="62" y="-2" width="3.2" height="3.2" rx="0.4" opacity="0.5" />
    <rect class="st-px" x="59" y="6" width="2.5" height="2.5" rx="0.3" opacity="0.35" />
    <rect class="st-px" x="65" y="1.5" width="2" height="2" rx="0.2" opacity="0.2" />
  </g>

  <!-- WORDMARK: "SyncTek" -->
  <text
    class="st-txt"
    x="84"
    y="51"
    font-family="Inter, system-ui, -apple-system, sans-serif"
    font-size="38"
    font-weight="600"
    font-style="italic"
    letter-spacing="-0.02em"
  >SyncTek</text>
</svg>
