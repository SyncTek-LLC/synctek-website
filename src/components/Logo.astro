---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<svg
  class:list={['logo-svg', className]}
  height={height}
  viewBox="0 0 370 40"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SyncTek"
>
  <defs>
    <clipPath id="globe-clip">
      <circle cx="20" cy="20" r="17"/>
    </clipPath>
  </defs>

  <style>
    .st-icon { stroke: #E5E5E5; fill: none; }
    .st-txt { fill: #E5E5E5; }

    :root:not(.dark) .st-icon { stroke: #171717; }
    :root:not(.dark) .st-txt { fill: #171717; }
  </style>

  <!-- Globe icon -->
  <g>
    <!-- Circle outline -->
    <circle class="st-icon" cx="20" cy="20" r="17" stroke-width="1.5"/>

    <!-- Lines cutting through the globe (clipped to circle) -->
    <g clip-path="url(#globe-clip)">
      <!-- Diagonal cut, upper-left to mid-right -->
      <line class="st-icon" x1="3" y1="8" x2="34" y2="16" stroke-width="1"/>
      <!-- Horizontal cut, slightly above center -->
      <line class="st-icon" x1="3" y1="20" x2="37" y2="18" stroke-width="1"/>
      <!-- Diagonal cut, left to lower-right -->
      <line class="st-icon" x1="6" y1="26" x2="37" y2="30" stroke-width="1"/>
      <!-- Vertical-ish cut on the left -->
      <line class="st-icon" x1="12" y1="3" x2="10" y2="37" stroke-width="1"/>
      <!-- Vertical-ish cut on the right -->
      <line class="st-icon" x1="28" y1="4" x2="32" y2="37" stroke-width="1"/>
    </g>

    <!-- Lines extending beyond the circle for "cut through" effect -->
    <line class="st-icon" x1="5" y1="7" x2="12" y2="5" stroke-width="1"/>
    <line class="st-icon" x1="33" y1="31" x2="39" y2="34" stroke-width="1"/>
  </g>

  <!-- Wordmark -->
  <text
    class="st-txt"
    x="48"
    y="32"
    font-family="'Orbitron', sans-serif"
    font-size="36"
    font-weight="700"
    letter-spacing="2"
    text-rendering="geometricPrecision"
    dominant-baseline="auto"
  >SYNCTEK</text>
</svg>
