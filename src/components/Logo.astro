---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---
<svg
  class:list={['logo-svg', className]}
  height={height}
  viewBox="0 0 280 72"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SyncTek"
>
  <defs>
    <!-- ====== DARK MODE GRADIENTS (chrome on dark bg) ====== -->

    <!-- Ribbon front face: top-lit chrome -->
    <linearGradient id="st-rb-front" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#D8D8D8" />
      <stop offset="30%" stop-color="#C0C0C0" />
      <stop offset="65%" stop-color="#909090" />
      <stop offset="100%" stop-color="#707070" />
    </linearGradient>

    <!-- Ribbon edge/side face: darker chrome for depth -->
    <linearGradient id="st-rb-edge" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#808080" />
      <stop offset="50%" stop-color="#606060" />
      <stop offset="100%" stop-color="#444444" />
    </linearGradient>

    <!-- Ribbon highlight strip: bright specular -->
    <linearGradient id="st-rb-hi" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F0F0F0" />
      <stop offset="50%" stop-color="#E0E0E0" />
      <stop offset="100%" stop-color="#C0C0C0" />
    </linearGradient>

    <!-- Ribbon underside/crossover shadow -->
    <linearGradient id="st-rb-under" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0%" stop-color="#888888" />
      <stop offset="50%" stop-color="#666666" />
      <stop offset="100%" stop-color="#4A4A4A" />
    </linearGradient>

    <!-- Text chrome -->
    <linearGradient id="st-text" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#F0F0F0" />
      <stop offset="25%" stop-color="#DCDCDC" />
      <stop offset="75%" stop-color="#A0A0A0" />
      <stop offset="100%" stop-color="#808080" />
    </linearGradient>

    <!-- ====== LIGHT MODE GRADIENTS (darkened for white bg) ====== -->

    <linearGradient id="st-rb-front-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#686868" />
      <stop offset="30%" stop-color="#585858" />
      <stop offset="65%" stop-color="#444444" />
      <stop offset="100%" stop-color="#353535" />
    </linearGradient>

    <linearGradient id="st-rb-edge-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#484848" />
      <stop offset="50%" stop-color="#363636" />
      <stop offset="100%" stop-color="#262626" />
    </linearGradient>

    <linearGradient id="st-rb-hi-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#787878" />
      <stop offset="50%" stop-color="#686868" />
      <stop offset="100%" stop-color="#555555" />
    </linearGradient>

    <linearGradient id="st-rb-under-lt" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0%" stop-color="#404040" />
      <stop offset="50%" stop-color="#303030" />
      <stop offset="100%" stop-color="#222222" />
    </linearGradient>

    <linearGradient id="st-text-lt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#333333" />
      <stop offset="25%" stop-color="#282828" />
      <stop offset="75%" stop-color="#1A1A1A" />
      <stop offset="100%" stop-color="#111111" />
    </linearGradient>
  </defs>

  <style>
    /* Dark mode (default) */
    .st-front { fill: url(#st-rb-front); }
    .st-edge  { fill: url(#st-rb-edge); }
    .st-hi    { fill: url(#st-rb-hi); }
    .st-under { fill: url(#st-rb-under); }
    .st-txt   { fill: url(#st-text); }
    .st-px    { fill: #B0B0B0; }

    /* Light mode */
    :root:not(.dark) .st-front { fill: url(#st-rb-front-lt); }
    :root:not(.dark) .st-edge  { fill: url(#st-rb-edge-lt); }
    :root:not(.dark) .st-hi    { fill: url(#st-rb-hi-lt); }
    :root:not(.dark) .st-under { fill: url(#st-rb-under-lt); }
    :root:not(.dark) .st-txt   { fill: url(#st-text-lt); }
    :root:not(.dark) .st-px    { fill: #505050; }
  </style>

  <!--
    S-RIBBON MARK
    A wide chrome ribbon bent into an S shape with 3D perspective.
    The ribbon has visible surface area (not just a stroke).
    Viewed from slight upper-left perspective.
  -->
  <g transform="translate(2, 2)">
    <!--
      UPPER CURVE: Ribbon flows from lower-left upward to upper-right.
      The top edge of the S. The "front face" of the ribbon is visible.
    -->

    <!-- Upper ribbon: front/bright face -->
    <path class="st-front" d="
      M 18,38
      C 14,30 14,18 24,10
      C 32,4 44,2 54,5
      L 58,8
      C 48,4 34,4 26,12
      C 18,20 20,32 22,36
      Z
    " />

    <!-- Upper ribbon: top highlight edge (specular strip along top) -->
    <path class="st-hi" d="
      M 24,10
      C 32,4 44,2 54,5
      L 56,3
      C 44,0 32,1 22,8
      Z
    " />

    <!-- Upper ribbon: bottom edge (dark, gives thickness) -->
    <path class="st-edge" d="
      M 18,38
      C 14,30 14,18 24,10
      L 22,8
      C 11,16 10,30 15,39
      Z
    " />

    <!-- Tip of upper ribbon (top-right end) -->
    <path class="st-front" d="
      M 54,5
      L 58,8
      C 61,9.5 63,9 64,7
      C 64.5,5.5 63,3 60,2.5
      L 56,3
      Z
    " />

    <!--
      CROSSOVER: The ribbon crosses over itself in the middle.
      This is the "bridge" connecting upper and lower curves.
      Rendered as a diagonal band from upper-right to lower-left.
    -->

    <!-- Crossover front face -->
    <path class="st-under" d="
      M 22,36
      C 26,40 32,43 38,43
      C 44,43 50,40 52,36
      C 50,32 44,28 38,28
      C 32,28 25,31 22,36
    " />

    <!-- Crossover highlight (top edge of the crossing band) -->
    <path class="st-front" d="
      M 22,36
      C 25,31 32,28 38,28
      C 44,28 50,32 52,36
      L 50,34
      C 48,30 43,27 38,27
      C 32,27 26,30 23,34
      Z
    " />

    <!--
      LOWER CURVE: Ribbon flows from upper-right downward to lower-left.
      The bottom part of the S. Mirror of the upper curve.
    -->

    <!-- Lower ribbon: front/bright face -->
    <path class="st-front" d="
      M 52,36
      C 56,44 56,54 46,62
      C 38,68 26,70 16,67
      L 12,64
      C 22,68 36,68 44,60
      C 52,52 50,40 48,36
      Z
    " />

    <!-- Lower ribbon: bottom highlight edge -->
    <path class="st-hi" d="
      M 46,62
      C 38,68 26,70 16,67
      L 14,69
      C 26,72 38,71 48,64
      Z
    " />

    <!-- Lower ribbon: top edge (dark, gives thickness) -->
    <path class="st-edge" d="
      M 52,36
      C 56,44 56,54 46,62
      L 48,64
      C 59,56 60,42 55,33
      Z
    " />

    <!-- Tip of lower ribbon (bottom-left end) -->
    <path class="st-front" d="
      M 16,67
      L 12,64
      C 9,62.5 7,63 6,65
      C 5.5,66.5 7,69 10,69.5
      L 14,69
      Z
    " />

    <!-- PIXEL DISSOLVE: Small squares at top-right end -->
    <rect class="st-px" x="63" y="1" width="3.5" height="3.5" rx="0.3" opacity="0.85" />
    <rect class="st-px" x="67.5" y="-0.5" width="2.8" height="2.8" rx="0.2" opacity="0.55" />
    <rect class="st-px" x="64.5" y="6" width="2.2" height="2.2" rx="0.2" opacity="0.4" />
    <rect class="st-px" x="71" y="1.5" width="1.8" height="1.8" rx="0.1" opacity="0.25" />
    <rect class="st-px" x="68.5" y="4.5" width="1.5" height="1.5" rx="0.1" opacity="0.18" />
  </g>

  <!-- WORDMARK: "SyncTek" -->
  <text
    class="st-txt"
    x="84"
    y="51"
    font-family="Inter, system-ui, -apple-system, sans-serif"
    font-size="38"
    font-weight="600"
    font-style="italic"
    letter-spacing="-0.02em"
  >SyncTek</text>
</svg>
