---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-6">
  <img
    src={src}
    alt={alt}
    class="rounded-lg w-full"
    loading="lazy"
    decoding="async"
  />
  {caption && (
    <figcaption class="mt-2 text-center text-sm text-light-gray-500 dark:text-muted">
      {caption}
    </figcaption>
  )}
</figure>
