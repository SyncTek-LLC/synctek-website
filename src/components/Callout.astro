---
interface Props {
  type?: 'note' | 'warning' | 'tip' | 'important';
}

const { type = 'note' } = Astro.props;

const styles: Record<string, { border: string; bg: string; icon: string; label: string }> = {
  note: {
    border: 'border-link-blue',
    bg: 'bg-link-blue/10',
    icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    label: 'Note',
  },
  warning: {
    border: 'border-warning-amber',
    bg: 'bg-warning-amber/10',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z',
    label: 'Warning',
  },
  tip: {
    border: 'border-sync-green',
    bg: 'bg-sync-green/10',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    label: 'Tip',
  },
  important: {
    border: 'border-error-red',
    bg: 'bg-error-red/10',
    icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    label: 'Important',
  },
};

const style = styles[type];
---

<div class:list={['rounded-lg border-l-4 p-4 my-4', style.border, style.bg]}>
  <div class="flex items-center gap-2 mb-2 font-semibold text-sm">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d={style.icon} />
    </svg>
    {style.label}
  </div>
  <div class="text-sm">
    <slot />
  </div>
</div>
