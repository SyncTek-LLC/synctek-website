---
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';

const navLinks = [
  { label: 'Products', href: '/products/' },
  { label: 'Docs', href: '/docs/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Open Source', href: '/open-source/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-light-border dark:border-border-gray bg-light-bg/80 dark:bg-obsidian/80 backdrop-blur-md">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline">
      <Logo height={36} class="sm:h-10" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium no-underline transition-colors',
            currentPath.startsWith(link.href)
              ? 'text-accent-silver-hover dark:text-terminal-white'
              : 'text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white',
          ]}
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
      <a
        href="https://forge-dashboard-production-6bd4.up.railway.app/login"
        class="inline-flex items-center px-4 py-1.5 rounded-md text-sm font-medium no-underline transition-all duration-150 text-[#E6EDF3]"
        style="border: 1px solid #3B82F6; color: #3B82F6;"
        onmouseover="this.style.background='rgba(59,130,246,0.10)'"
        onmouseout="this.style.background='transparent'"
      >
        Sign In
      </a>
    </div>

    <!-- Mobile hamburger -->
    <div class="flex items-center gap-2 lg:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        class="p-2 rounded-lg hover:bg-light-surface dark:hover:bg-border-gray"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <!-- Backdrop -->
    <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50"></div>
    <!-- Menu panel -->
    <div class="absolute right-0 top-0 h-full w-72 bg-light-bg dark:bg-obsidian border-l border-light-border dark:border-border-gray p-6">
      <div class="flex justify-end mb-8">
        <button
          id="mobile-menu-close"
          type="button"
          aria-label="Close navigation menu"
          class="p-2 rounded-lg hover:bg-light-surface dark:hover:bg-border-gray"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-lg font-medium no-underline py-2 transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-accent-silver-hover dark:text-terminal-white'
                : 'text-light-gray-500 dark:text-muted hover:text-light-text-primary dark:hover:text-terminal-white',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://forge-dashboard-production-6bd4.up.railway.app/login"
          class="inline-flex items-center justify-center px-4 py-2.5 rounded-md text-base font-medium no-underline transition-all duration-150 mt-2"
          style="border: 1px solid #3B82F6; color: #3B82F6;"
        >
          Sign In
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const closeBtn = document.getElementById('mobile-menu-close');

    function open() {
      menu?.classList.remove('hidden');
      btn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn?.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
        close();
      }
    });

    // Close on navigation
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', close);
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
